{
  "name": "paga-diario",
  "version": "1.0.0",
  "description": "API para gestión de préstamos diarios - Paga Diario",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:node": "node --watch src/server.js",
    "lint": "eslint 'src/**/*.js' 'tests/**/*.js'",
    "lint:fix": "eslint 'src/**/*.js' 'tests/**/*.js' --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'tests/**/*.js'",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:generate": "prisma generate --accelerate",
    "deploy:fly": "npx prisma generate --accelerate && prisma migrate deploy",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --minify",
    "build:css:watch": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --watch",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop paga-diario",
    "pm2:restart": "pm2 restart paga-diario",
    "pm2:logs": "pm2 logs paga-diario",
    "pm2:monit": "pm2 monit"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "prestamos",
    "fintech",
    "paga-diario"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@prisma/client": "5.14.0",
    "bcrypt": "5.1.1",
    "bullmq": "5.7.14",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.11",
    "decimal.js": "10.4.3",
    "dotenv": "16.4.5",
    "ejs": "3.1.10",
    "exceljs": "^4.4.0",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "ioredis": "5.3.2",
    "jsonwebtoken": "9.0.2",
    "method-override": "^3.0.0",
    "node-telegram-bot-api": "0.66.0",
    "pdfkit": "^0.17.2",
    "pdfkit-table": "^0.1.99",
    "prisma": "5.14.0",
    "socket.io": "4.7.5",
    "tailwindcss": "3.4.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@jest/globals": "^30.2.0",
    "eslint": "8.57.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.29.1",
    "jest": "29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "3.3.2",
    "supertest": "^7.2.2"
  }
}
