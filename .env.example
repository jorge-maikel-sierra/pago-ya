```bash
# ============================================
# Pago Ya - Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA versiones .env con valores reales
# ============================================

# --- Entorno ---
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# --- Base de Datos (PostgreSQL) ---
DATABASE_URL=postgresql://usuario:password@localhost:5432/pago_ya?schema=public
# DIRECT_URL: usado por Prisma Migrate en entornos con connection pooler (ej. Prisma Data Platform)
DIRECT_URL=postgresql://usuario:password@localhost:5432/pago_ya?schema=public

# --- Redis (BullMQ / Colas de trabajo) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL: alternativa a REDIS_HOST/PORT para PaaS (ej. Upstash, Railway)
REDIS_URL=

# --- JWT (Autenticación) ---
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-32-caracteres
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-seguro-de-al-menos-32-caracteres
JWT_REFRESH_EXPIRES_IN=7d

# --- Telegram (Notificaciones) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# --- Tasas de Usura (Regulación Colombiana) ---
# Tasa de usura vigente expresada como porcentaje anual (ej: 28.47)
USURY_RATE_ANNUAL=28.47
# Tasa de interés de mora permitida (1.5x la tasa del crédito, máximo usura — Ley 510/99)
DEFAULT_MORA_RATE_ANNUAL=28.47

# --- Sesión / Cookies ---
SESSION_SECRET=cambia-esto-por-un-secreto-de-sesion-de-al-menos-32-caracteres

# --- Debug (opcional) ---
# DEBUG_KEY: clave para endpoints de diagnóstico internos (dejar vacío en producción)
DEBUG_KEY=
```
