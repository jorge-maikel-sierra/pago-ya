# ============================================
# Paga Diario - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================

# --- Entorno ---
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# --- Base de Datos (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://usuario:password@localhost:5432/paga_diario?schema=public

# --- Redis (BullMQ / Colas de trabajo) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (Autenticación) ---
JWT_SECRET=cambia-esto-por-un-secreto-seguro
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-seguro
JWT_REFRESH_EXPIRES_IN=7d

# --- Telegram (Notificaciones) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# --- Tasas de Usura (Regulación Colombiana) ---
# Tasa de usura vigente expresada como porcentaje anual (ej: 28.47)
USURY_RATE_ANNUAL=28.47
# Tasa de interés de mora permitida (1.5x la tasa del crédito, máximo usura)
DEFAULT_MORA_RATE_ANNUAL=28.47

# --- Sesión / Cookies ---
SESSION_SECRET=cambia-esto-por-un-secreto-de-sesion
