<% if (typeof flashSucess !== 'undefined' && flashSucess) { %>
  <div id="flash-success"
       class="mx-4 sm:mx-6 mt-4 rounded-lg bg-green-50 border border-green-200 p-4
              transition-all duration-500 ease-in-out"
       role="alert">
    <div class="flex items-center gap-2">
      <span class="text-green-600 text-lg">✅</span>
      <p class="text-sm font-medium text-green-800"><%= flashSucess %></p>
    </div>
  </div>
<% } %>

<% if (typeof flashError !== 'undefined' && flashError) { %>
  <div id="flash-error"
       class="mx-4 sm:mx-6 mt-4 rounded-lg bg-red-50 border border-red-200 p-4
              transition-all duration-500 ease-in-out"
       role="alert">
    <div class="flex items-center gap-2">
      <span class="text-red-600 text-lg">❌</span>
      <p class="text-sm font-medium text-red-800"><%= flashError %></p>
    </div>
  </div>
<% } %>

<script>
  // Auto-dismiss flash messages con transición suave tras 4 segundos
  (function dismissFlashMessages() {
    const VISIBLE_MS  = 4000; // tiempo visible antes de iniciar el fade
    const FADE_MS     = 500;  // duración del fade (debe coincidir con duration-500 de Tailwind)

    ['flash-success', 'flash-error'].forEach(function (id) {
      const el = document.getElementById(id);
      if (!el) return;

      setTimeout(function () {
        el.style.opacity    = '0';
        el.style.transform  = 'translateY(-6px)';

        // Elimina el nodo del DOM una vez terminada la animación para no dejar espacio vacío
        setTimeout(function () { el.remove(); }, FADE_MS);
      }, VISIBLE_MS);
    });
  })();
</script>
