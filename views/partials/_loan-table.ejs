<%
/**
 * Partial: _loan-table.ejs
 * Recibe: loans (Array de objetos Loan con client y collector incluidos)
 *
 * Formatea valores monetarios en COP.
 * @param {number|string} amount
 * @returns {string}
 */
function formatCOP(amount) {
  if (amount == null) return '—';
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: 'COP',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
}

/**
 * Formatea una fecha ISO a formato colombiano dd/mm/aaaa.
 * @param {Date|string} date
 * @returns {string}
 */
function formatDate(date) {
  if (!date) return '—';
  return new Date(date).toLocaleDateString('es-CO', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

/**
 * Retorna clases Tailwind para el badge de estado del préstamo.
 * @param {string} loanStatus
 * @returns {{ bg: string, text: string, label: string }}
 */
function statusBadge(loanStatus) {
  const map = {
    ACTIVE:    { bg: 'bg-green-100',  text: 'text-green-700',  label: 'Activo'      },
    PENDING:   { bg: 'bg-yellow-100', text: 'text-yellow-700', label: 'Pendiente'   },
    COMPLETED: { bg: 'bg-blue-100',   text: 'text-blue-700',   label: 'Completado'  },
    DEFAULTED: { bg: 'bg-red-100',    text: 'text-red-700',    label: 'En mora'     },
    CANCELLED: { bg: 'bg-gray-100',   text: 'text-gray-600',   label: 'Cancelado'   },
  };
  return map[loanStatus] || { bg: 'bg-gray-100', text: 'text-gray-500', label: loanStatus };
}
%>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">

  <% if (!loans || loans.length === 0) { %>
    <!-- Estado vacío -->
    <div class="py-16 text-center">
      <span class="text-5xl block mb-4">💳</span>
      <p class="text-base font-medium text-gray-500">No se encontraron préstamos</p>
      <p class="text-sm text-gray-400 mt-1">Intenta cambiar los filtros o crea un nuevo préstamo.</p>
      <a href="/admin/loans/new"
         class="mt-4 inline-flex items-center gap-1 px-4 py-2 rounded-lg bg-brand-green text-white
                text-sm font-semibold hover:bg-green-500 transition-colors">
        ➕ Nuevo Préstamo
      </a>
    </div>

  <% } else { %>

    <!-- Tabla visible en pantallas md+ -->
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Cliente
            </th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Capital
            </th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Saldo Pendiente
            </th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Cuota
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Cuotas
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Estado
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Desembolso
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Cobrador
            </th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
              Acciones
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% loans.forEach(function(loan) { %>
            <%
              const badge = statusBadge(loan.status);
              const clientName = loan.client
                ? loan.client.firstName + ' ' + loan.client.lastName
                : '—';
              const collectorName = loan.collector
                ? loan.collector.firstName + ' ' + loan.collector.lastName
                : '—';
            %>
            <tr class="hover:bg-gray-50 transition-colors">

              <!-- Cliente -->
              <td class="px-4 py-3">
                <span class="font-medium text-brand-navy"><%= clientName %></span>
              </td>

              <!-- Capital -->
              <td class="px-4 py-3 text-right tabular-nums text-gray-700">
                <%= formatCOP(loan.principalAmount) %>
              </td>

              <!-- Saldo Pendiente -->
              <td class="px-4 py-3 text-right tabular-nums">
                <% if (loan.status === 'DEFAULTED') { %>
                  <span class="font-semibold text-red-600"><%= formatCOP(loan.outstandingBalance) %></span>
                <% } else { %>
                  <span class="text-gray-700"><%= formatCOP(loan.outstandingBalance) %></span>
                <% } %>
              </td>

              <!-- Cuota -->
              <td class="px-4 py-3 text-right tabular-nums text-gray-700">
                <%= formatCOP(loan.installmentAmount) %>
              </td>

              <!-- Cuotas pagadas / total -->
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center gap-1 text-gray-600">
                  <span class="font-semibold text-brand-navy"><%= loan.paidPayments %></span>
                  <span class="text-gray-400">/</span>
                  <span><%= loan.numberOfPayments %></span>
                </span>
              </td>

              <!-- Estado -->
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                             <%= badge.bg %> <%= badge.text %>">
                  <%= badge.label %>
                </span>
              </td>

              <!-- Fecha de desembolso -->
              <td class="px-4 py-3 text-center text-gray-600">
                <%= formatDate(loan.disbursementDate) %>
              </td>

              <!-- Cobrador -->
              <td class="px-4 py-3 text-center text-gray-600">
                <%= collectorName %>
              </td>

              <!-- Acciones -->
              <td class="px-4 py-3 text-center">
                <a href="/admin/loans/<%= loan.id %>"
                   class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg border border-gray-300
                          text-xs font-medium text-gray-600 hover:bg-gray-100 transition-colors">
                  Ver detalle →
                </a>
              </td>

            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

  <% } %>
</div>
