<aside class="w-64 bg-brand-navy min-h-screen border-r border-gray-700 hidden lg:block">
  <nav class="mt-6 px-3 space-y-1">
    <% const menuItems = [
      { href: '/admin/dashboard', icon: '📊', label: 'Dashboard' },
      // Reordenado: primero Clientes, luego Cobradores, Rutas, Préstamos y Reportes
      { href: '/admin/clients', icon: '👥', label: 'Clientes' },
      { href: '/admin/collectors', icon: '🧑‍💼', label: 'Cobradores' },
      { href: '/admin/routes', icon: '🗺️', label: 'Rutas' },
      { href: '/admin/loans', icon: '�', label: 'Préstamos' },
      { href: '/admin/reports', icon: '📈', label: 'Reportes' },
      { href: '/admin/payments', icon: '💵', label: 'Pagos' },
    ]; %>

    <% menuItems.forEach(item => { %>
      <a href="<%= item.href %>"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
          <%= (typeof currentPath !== 'undefined' && currentPath === item.href)
            ? 'bg-brand-green/10 text-brand-green'
            : 'text-gray-400 hover:bg-gray-800 hover:text-white' %>">
        <span><%= item.icon %></span>
        <span><%= item.label %></span>
      </a>
    <% }); %>
  </nav>

  <% if (typeof user !== 'undefined' && user.role === 'SUPER_ADMIN') { %>
    <div class="mt-8 px-3">
      <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">
        Administración
      </p>
      <nav class="mt-2 space-y-1">
        <a href="/admin/organizations"
          class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
          <span>🏢</span>
          <span>Organizaciones</span>
        </a>
        <a href="/admin/users"
          class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
          <span>👤</span>
          <span>Usuarios</span>
        </a>
      </nav>
    </div>
  <% } %>
</aside>
