<%- include('layouts/header') %>

<div class="flex items-center justify-center min-h-[60vh] p-4 sm:p-6 lg:p-8">
  <div class="w-full max-w-lg text-center space-y-6">

    <p class="text-7xl font-bold text-brand-navy"><%= statusCode %></p>

    <h1 class="text-2xl font-semibold text-gray-900"><%= message %></h1>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <ul class="text-left bg-red-50 border border-red-200 rounded-lg p-4 space-y-1">
        <% errors.forEach((err) => { %>
          <li class="text-sm text-red-700">
            <% if (err.field) { %>
              <span class="font-medium"><%= err.field %>:</span>
            <% } %>
            <%= err.message %>
          </li>
        <% }); %>
      </ul>
    <% } %>

    <% if (typeof stack !== 'undefined' && stack) { %>
      <details class="text-left">
        <summary class="cursor-pointer text-sm text-gray-400 hover:text-gray-600">Stack trace</summary>
        <pre class="mt-2 bg-gray-900 text-green-400 text-xs p-4 rounded-lg overflow-x-auto"><%= stack %></pre>
      </details>
    <% } %>

    <a href="/admin/dashboard"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium text-white bg-brand-green hover:bg-brand-green/90 transition-colors">
      ← Volver al Dashboard
    </a>

  </div>
</div>

<%- include('layouts/footer') %>
