<%- include('../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Clientes</h1>
      <p class="text-sm text-gray-500 mt-1">Directorio de clientes de la organización</p>
    </div>
  </div>

  <!-- Tabla de clientes -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-gray-700">Nombre</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-700">Documento</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-700">Teléfono</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-700">Email</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-700">Creado</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-700">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (clients.length === 0) { %>
          <tr>
            <td colspan="6" class="px-4 py-6 text-center text-gray-400">
              <span class="text-4xl mb-2">👥</span><br>
              No hay clientes registrados.
            </td>
          </tr>
        <% } else { %>
          <% clients.forEach(client => { %>
            <tr class="border-b last:border-none">
              <td class="px-4 py-3">
                <a href="/admin/clients/<%= client.id %>" class="text-brand-navy font-medium hover:underline">
                  <%= client.firstName %> <%= client.lastName %>
                </a>
              </td>
              <td class="px-4 py-3"><%= client.documentNumber %></td>
              <td class="px-4 py-3"><%= client.phone %></td>
              <td class="px-4 py-3"><%= client.email %></td>
              <td class="px-4 py-3"><%= new Date(client.createdAt).toLocaleDateString('es-CO') %></td>
              <td class="px-4 py-3">
                <a href="/admin/clients/<%= client.id %>" class="text-brand-green hover:underline">Ver</a>
              </td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<%- include('../layouts/footer') %>
