<%- include('../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Reportes</h1>
      <p class="text-sm text-gray-500 mt-1">Generación y descarga de reportes</p>
    </div>
  </div>

  <!-- Export cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

    <!-- Excel export -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <div class="text-center space-y-4">
        <span class="text-4xl block">📊</span>
        <h3 class="text-lg font-semibold text-brand-navy">Cartera del día (Excel)</h3>
        <p class="text-sm text-gray-500">Descarga el reporte de cobro del día en formato .xlsx</p>
        <a href="/admin/reports/export?format=xlsx"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-brand-green text-white text-sm font-semibold shadow-sm hover:bg-green-500 transition-colors">
          📥 Descargar Excel
        </a>
      </div>
    </div>

    <!-- PDF export -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <div class="text-center space-y-4">
        <span class="text-4xl block">📄</span>
        <h3 class="text-lg font-semibold text-brand-navy">Reporte PDF</h3>
        <p class="text-sm text-gray-500">Genera un PDF detallado en segundo plano</p>
        <a href="/admin/reports/export?format=pdf"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-brand-navy text-white text-sm font-semibold shadow-sm hover:bg-gray-800 transition-colors">
          📄 Generar PDF
        </a>
      </div>
    </div>

  </div>

</div>

<%- include('../layouts/footer') %>
