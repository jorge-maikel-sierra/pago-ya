<%
/**
 * Vista: collectors/new.ejs
 * Formulario para crear un nuevo cobrador.
 *
 * Variables locales esperadas:
 * - title: Título de la página
 * - user: Usuario autenticado
 * - currentPath: Ruta activa para el sidebar
 * - flashError: Mensaje de error opcional
 */
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/collectors"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-300
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Crear Nuevo Cobrador</h1>
      <p class="text-sm text-gray-500 mt-1">Añade un cobrador a tu organización</p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-600 text-lg">❌</span>
        <p class="text-sm font-medium text-red-800"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/collectors"
        class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 max-w-2xl">

    <!-- Información Personal -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        👤 Información Personal
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Nombre -->
        <div>
          <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
            Nombre <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            required
            minlength="2"
            maxlength="80"
            placeholder="Ej: Juan"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Apellido -->
        <div>
          <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
            Apellido <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            minlength="2"
            maxlength="80"
            placeholder="Ej: Pérez"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
            Email <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            maxlength="100"
            placeholder="cobrador@empresa.com"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Teléfono -->
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
            Teléfono
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            maxlength="20"
            placeholder="+57 300 123 4567"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

      </div>
    </div>

    <!-- Acceso -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        🔐 Acceso
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Contraseña -->
        <div class="md:col-span-2">
          <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
            Contraseña <span class="text-red-500">*</span>
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="6"
            maxlength="100"
            placeholder="Mínimo 6 caracteres"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

      </div>
    </div>

    <!-- =========================================
         BOTONES DE ACCIÓN
    ========================================= -->
    <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-gray-100">
      <button type="submit"
              class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg
                     bg-brand-green text-white text-sm font-semibold
                     hover:bg-green-500 transition-colors shadow-sm">
        ✅ Crear Cobrador
      </button>
      <a href="/admin/collectors"
         class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg
                border border-gray-300 text-gray-600 text-sm font-medium
                hover:bg-gray-50 transition-colors">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>
