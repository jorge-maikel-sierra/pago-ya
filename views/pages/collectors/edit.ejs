<%
/**
 * Vista: collectors/edit.ejs
 * Formulario para editar un cobrador existente.
 *
 * Variables locales esperadas:
 * - title: Título de la página
 * - user: Usuario autenticado
 * - currentPath: Ruta activa para el sidebar
 * - collector: Objeto cobrador a editar
 * - flashError: Mensaje de error opcional
 */
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/collectors"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-300
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Editar Cobrador</h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= collector.firstName %> <%= collector.lastName %>
      </p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-600 text-lg">❌</span>
        <p class="text-sm font-medium text-red-800"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/collectors/<%= collector.id %>?_method=PUT"
        class="form-card max-w-2xl">

    <!-- Información Personal -->
    <div class="form-section">
      <h2 class="form-section-title">👤 Información Personal</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Nombre -->
        <div class="form-group">
          <label for="firstName" class="form-label">
            Nombre <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            required
            minlength="2"
            maxlength="80"
            value="<%= collector.firstName %>"
            placeholder="Ej: Juan"
            class="form-input"
          />
        </div>

        <!-- Apellido -->
        <div class="form-group">
          <label for="lastName" class="form-label">
            Apellido <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            minlength="2"
            maxlength="80"
            value="<%= collector.lastName %>"
            placeholder="Ej: Pérez"
            class="form-input"
          />
        </div>

        <!-- Email -->
        <div class="form-group">
          <label for="email" class="form-label">
            Email <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            maxlength="100"
            value="<%= collector.email %>"
            placeholder="cobrador@empresa.com"
            class="form-input"
          />
        </div>

        <!-- Teléfono -->
        <div class="form-group">
          <label for="phone" class="form-label">Teléfono</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            maxlength="20"
            value="<%= collector.phone || '' %>"
            placeholder="+57 300 123 4567"
            class="form-input"
          />
        </div>

      </div>
    </div>

    <!-- Acceso y Estado -->
    <div class="form-section">
      <h2 class="form-section-title">🔐 Acceso y Estado</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Contraseña -->
        <div class="form-group">
          <label for="password" class="form-label">Nueva Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            minlength="6"
            maxlength="100"
            placeholder="Dejar en blanco para no cambiar"
            class="form-input"
          />
          <p class="form-hint">Solo completa si deseas cambiar la contraseña actual.</p>
        </div>

        <!-- Estado -->
        <div class="flex items-end pb-3">
          <div class="flex items-center gap-3">
            <input type="hidden" name="isActive" value="false" />
            <input
              type="checkbox"
              id="isActive"
              name="isActive"
              value="true"
              <%= collector.isActive ? 'checked' : '' %>
              class="w-5 h-5 rounded border-gray-300 bg-white text-brand-green accent-brand-green
                     focus:ring-brand-green focus:ring-offset-0"
            />
            <label for="isActive" class="text-sm font-medium text-gray-700">
              Cobrador activo
              <span class="text-gray-400 font-normal">(puede iniciar sesión)</span>
            </label>
          </div>
        </div>

      </div>
    </div>

    <!-- =========================================
         BOTONES DE ACCIÓN
    ========================================= -->
    <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-gray-100">
      <button type="submit" class="flex-1 btn-primary justify-center">
        💾 Guardar Cambios
      </button>
      <a href="/admin/collectors" class="flex-1 btn-secondary justify-center">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>