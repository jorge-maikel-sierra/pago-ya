<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- Encabezado de página -->
  <div class="flex items-center gap-2">
    <a href="/admin/loans"
       class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-brand-navy transition-colors">
      ← Volver a préstamos
    </a>
  </div>

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Nuevo Préstamo</h1>
      <p class="text-sm text-gray-500 mt-1">Completa los datos para registrar y calcular un préstamo.</p>
    </div>
  </div>

  <!-- Errores de validación -->
  <% if (Array.isArray(validationErrors) && validationErrors.length > 0) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-800">
      <p class="font-semibold mb-2">Por favor corrige los siguientes campos:</p>
      <ul class="list-disc list-inside space-y-1">
        <% validationErrors.forEach(function(err) { %>
          <li><strong><%= err.field %>:</strong> <%= err.message %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <!-- Formulario principal -->
  <form id="loan-form"
        method="POST"
        action="/admin/loans"
        class="bg-white rounded-xl border border-gray-200 shadow-sm">

    <!-- ── Sección 1: Datos del solicitante ────────────────────────── -->
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-brand-navy uppercase tracking-wide">
        Datos del solicitante
      </h2>
    </div>

    <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-5">

      <!-- clientId: Cliente (typeahead) -->
      <div>
        <label for="clientSearch" class="form-label">
          Cliente <span class="text-red-500">*</span>
        </label>
        <input
          id="clientSearch"
          name="clientSearch"
          autocomplete="off"
          type="text"
          placeholder="Escribe nombre, cédula o NIT..."
          value="<%= formData && formData.clientName ? formData.clientName : '' %>"
          required
          class="form-input"
        />
        <input type="hidden" id="clientId" name="clientId" value="<%= formData ? formData.clientId : '' %>" />
        <div id="clientSuggestions" class="mt-1 bg-white border border-gray-200 rounded-md shadow-sm hidden max-h-60 overflow-auto text-sm"></div>
        <noscript>
          <select
            id="clientId_noscript"
            name="clientId"
            required
            class="form-select mt-2"
          >
            <option value="">— Selecciona un cliente —</option>
            <% clients.forEach(function(client) { %>
              <option value="<%= client.id %>" <%= formData && formData.clientId === client.id ? 'selected' : '' %>>
                <%= client.lastName %>, <%= client.firstName %> (<%= client.documentNumber %>)
              </option>
            <% }); %>
          </select>
        </noscript>
        <% if (!clients || clients.length === 0) { %>
          <p class="form-hint text-amber-600">
            No hay clientes activos registrados.
            <a href="/admin/clients/new" class="underline hover:text-amber-800">Registrar cliente</a>
          </p>
        <% } %>
      </div>

      <!-- collectorId: Cobrador (typeahead) -->
      <div>
        <label for="collectorSearch" class="form-label">
          Cobrador <span class="text-red-500">*</span>
        </label>
        <input
          id="collectorSearch"
          name="collectorSearch"
          autocomplete="off"
          type="text"
          placeholder="Escribe nombre o cédula..."
          value="<%= formData && formData.collectorName ? formData.collectorName : '' %>"
          required
          class="form-input"
        />
        <input type="hidden" id="collectorId" name="collectorId" value="<%= formData ? formData.collectorId : '' %>" />
        <div id="collectorSuggestions" class="mt-1 bg-white border border-gray-200 rounded-md shadow-sm hidden max-h-60 overflow-auto text-sm"></div>
        <noscript>
          <select
            id="collectorId_noscript"
            name="collectorId"
            required
            class="form-select mt-2"
          >
            <option value="">— Selecciona un cobrador —</option>
            <% collectors.forEach(function(collector) { %>
              <option value="<%= collector.id %>" <%= formData && formData.collectorId === collector.id ? 'selected' : '' %>>
                <%= collector.firstName %> <%= collector.lastName %>
              </option>
            <% }); %>
          </select>
        </noscript>
        <% if (!collectors || collectors.length === 0) { %>
          <p class="form-hint text-amber-600">
            No hay cobradores registrados.
          </p>
        <% } %>
      </div>

      <!-- routeId: Ruta de cobro (typeahead, opcional) -->
      <div>
        <label for="routeSearch" class="form-label">
          Ruta de cobro
          <span class="text-xs text-gray-400 font-normal">(opcional)</span>
        </label>
        <input
          id="routeSearch"
          name="routeSearch"
          autocomplete="off"
          type="text"
          placeholder="Escribe nombre o código de ruta..."
          value="<%= formData && formData.routeName ? formData.routeName : '' %>"
          class="form-input"
        />
        <input type="hidden" id="routeId" name="routeId" value="<%= formData ? formData.routeId : '' %>" />
        <div id="routeSuggestions" class="mt-1 bg-white border border-gray-200 rounded-md shadow-sm hidden max-h-60 overflow-auto text-sm"></div>
        <noscript>
          <select
            id="routeId_noscript"
            name="routeId"
            class="form-select mt-2"
          >
            <option value="">— Sin ruta asignada —</option>
            <% routes.forEach(function(route) { %>
              <option value="<%= route.id %>" <%= formData && formData.routeId === route.id ? 'selected' : '' %>><%= route.name %></option>
            <% }); %>
          </select>
        </noscript>
      </div>

    </div>

    <!-- ── Sección 2: Condiciones del préstamo ─────────────────────── -->
    <div class="px-6 py-4 border-t border-b border-gray-100">
      <h2 class="text-sm font-semibold text-brand-navy uppercase tracking-wide">
        Condiciones del préstamo
      </h2>
    </div>

    <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-6 gap-y-5">
      <div>
        <label for="principalAmount" class="form-label">
          Capital prestado (COP) <span class="text-red-500">*</span>
        </label>
        <div class="relative">
          <span class="absolute inset-y-0 left-3 flex items-center text-gray-400 text-sm pointer-events-none">
            $
          </span>
          <input
            id="principalAmount"
            type="number"
            name="principalAmount"
            min="0.01"
            step="0.01"
            placeholder="500000.00"
            value="<%= formData ? formData.principalAmount : '' %>"
            required
            class="form-input pl-7"
          />
        </div>
        <p class="form-hint">Monto neto desembolsado al cliente.</p>
      </div>

      <!-- interestRate: Tasa de interés total del préstamo -->
      <div>
        <label for="interestRate" class="form-label">
          Tasa de interés total (%) <span class="text-red-500">*</span>
        </label>
        <div class="relative">
          <input
            id="interestRate"
            type="number"
            name="interestRate"
            min="0"
            max="100"
            step="0.01"
            placeholder="5"
            value="<%= formData ? formData.interestRate : '' %>"
            required
            class="form-input pr-8"
          />
          <span class="absolute inset-y-0 right-3 flex items-center text-gray-400 text-sm pointer-events-none">
            %
          </span>
        </div>
        <p class="form-hint">Interés mensual sobre el capital (ej.&nbsp;10 = 10% por mes).</p>
      </div>

      <!-- paymentFrequency: Frecuencia de pago (enum PaymentFrequency) -->
      <div>
        <label for="paymentFrequency" class="form-label">
          Frecuencia de pago <span class="text-red-500">*</span>
        </label>
        <select
          id="paymentFrequency"
          name="paymentFrequency"
          required
          class="form-select"
        >
          <option value="">— Selecciona la frecuencia —</option>
          <option value="DAILY" <%= formData && formData.paymentFrequency === 'DAILY' ? 'selected' : '' %>>Diario</option>
          <option value="WEEKLY" <%= formData && formData.paymentFrequency === 'WEEKLY' ? 'selected' : '' %>>Semanal</option>
          <option value="BIWEEKLY" <%= formData && formData.paymentFrequency === 'BIWEEKLY' ? 'selected' : '' %>>Quincenal</option>
          <option value="MONTHLY" <%= formData && formData.paymentFrequency === 'MONTHLY' ? 'selected' : '' %>>Mensual</option>
        </select>
      </div>

      <!-- amortizationType: siempre FIXED (interés simple) — campo oculto -->
      <input type="hidden" name="amortizationType" value="FIXED" />

      <!-- termMonths: Plazo en meses — el engine calcula cuotas automáticamente -->
      <div>
        <label for="termMonths" class="form-label">
          Plazo <span class="text-red-500">*</span>
        </label>
        <div class="relative">
          <input
            id="termMonths"
            type="number"
            name="termMonths"
            min="1"
            max="24"
            step="1"
            placeholder="1"
            value="<%= formData ? formData.termMonths : '' %>"
            required
            class="form-input pr-16"
          />
          <span class="absolute inset-y-0 right-3 flex items-center text-gray-400 text-sm pointer-events-none">
            mes(es)
          </span>
        </div>
        <%# loan-calculator.js actualiza este párrafo dinámicamente al cambiar frecuencia o plazo %>
        <p id="termMonths-hint" class="form-hint">
          Selecciona la frecuencia para ver las cuotas estimadas.
        </p>
      </div>

      <!-- disbursementDate: Fecha de desembolso -->
      <div>
        <label for="disbursementDate" class="form-label">
          Fecha de desembolso <span class="text-red-500">*</span>
        </label>
        <input
          id="disbursementDate"
          type="date"
          name="disbursementDate"
          required
          value="<%= formData ? formData.disbursementDate : new Date().toISOString().slice(0, 10) %>"
          class="form-input"
        />
      </div>

    </div>

    <!-- ── Sección 3: Notas internas (opcional) ────────────────────── -->
    <div class="px-6 pb-6">
      <label for="notes" class="form-label">
        Notas internas
        <span class="text-xs text-gray-400 font-normal">(opcional)</span>
      </label>
      <textarea
        id="notes"
        name="notes"
        rows="3"
        placeholder="Observaciones sobre el préstamo o el cliente..."
        class="form-textarea"
      ><%= formData ? formData.notes : '' %></textarea>
    </div>

    <!-- ── Botones de acción ────────────────────────────────────────── -->
    <div class="px-6 py-4 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-3">

      <!-- Calcular previsualización (AJAX, no envía el formulario) -->
      <button
        type="button"
        id="btn-preview"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-5 py-3
               rounded-lg border border-brand-navy text-brand-navy text-sm font-semibold
               hover:bg-brand-navy hover:text-white transition-colors"
      >
        🔢 Calcular previsualización
      </button>

      <div class="flex items-center gap-3 w-full sm:w-auto">
        <a href="/admin/loans" class="flex-1 sm:flex-none btn-secondary">
          Cancelar
        </a>
        <!-- Crear Préstamo (submit) -->
        <button
          type="submit"
          id="btn-submit"
          class="flex-1 sm:flex-none btn-primary"
        >
          💾 Crear Préstamo
        </button>
      </div>
    </div>

  </form>

  <!-- ── Previsualización del cronograma (llenado vía AJAX) ─────────── -->
  <div id="schedule-preview">
    <%#
      loan-calculator.js inyecta aquí la tabla de amortización
      cuando el usuario pulsa "Calcular previsualización".
      El contenedor comienza vacío; el script lo muestra/oculta.
    %>
  </div>

</div><!-- /p-4 -->

<!-- Motor de cálculo del lado del cliente -->
<script src="/js/loan-calculator.js" defer></script>

<%- include('../../layouts/footer') %>
