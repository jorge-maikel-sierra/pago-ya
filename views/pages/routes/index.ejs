<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Gestión de Rutas</h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= routes.length %> ruta<%= routes.length !== 1 ? 's' : '' %> registrada<%= routes.length !== 1 ? 's' : '' %>
      </p>
    </div>
    <a href="/admin/routes/new"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-brand-green text-white
             text-sm font-semibold shadow-sm hover:bg-green-500 transition-colors whitespace-nowrap">
      + Nueva Ruta
    </a>
  </div>

  <!-- =========================================
       ESTADO VACÍO
  ========================================= -->
  <% if (routes.length === 0) { %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm py-20 text-center">
      <span class="text-5xl block mb-4">🗺️</span>
      <p class="text-base font-semibold text-gray-600">No hay rutas registradas</p>
      <p class="text-sm text-gray-400 mt-1">Crea la primera ruta para comenzar a organizar los cobros.</p>
      <a href="/admin/routes/new"
        class="mt-5 inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-brand-green
               text-white text-sm font-semibold hover:bg-green-500 transition-colors">
        + Nueva Ruta
      </a>
    </div>

  <% } else { %>

  <!-- =========================================
       TABLA DE RUTAS
  ========================================= -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">
            Nombre de la Ruta
          </th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">
            Descripción
          </th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">
            Cobrador asignado
          </th>
          <th class="px-5 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wide">
            Clientes
          </th>
          <th class="px-5 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wide">
            Estado
          </th>
          <th class="px-5 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wide">
            Acciones
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% routes.forEach(function(route) { %>
          <tr class="hover:bg-gray-50 transition-colors">

            <!-- Nombre de la ruta -->
            <td class="px-5 py-4">
              <span class="font-semibold text-brand-navy"><%= route.name %></span>
            </td>

            <!-- Descripción -->
            <td class="px-5 py-4 text-gray-500 text-xs max-w-xs">
              <% if (route.description) { %>
                <%= route.description %>
              <% } else { %>
                <span class="text-gray-300 italic">—</span>
              <% } %>
            </td>

            <!-- Cobrador asignado -->
            <td class="px-5 py-4">
              <% if (route.collector) { %>
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-full bg-brand-navy flex items-center justify-center
                              text-white text-xs font-bold shrink-0">
                    <%= route.collector.firstName.charAt(0).toUpperCase() %><%= route.collector.lastName.charAt(0).toUpperCase() %>
                  </div>
                  <span class="text-sm font-medium text-gray-700">
                    <%= route.collector.firstName %> <%= route.collector.lastName %>
                  </span>
                </div>
              <% } else { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full
                             text-xs font-semibold bg-yellow-50 text-yellow-700 border border-yellow-200">
                  ⚠ Sin cobrador asignado
                </span>
              <% } %>
            </td>

            <!-- Número de clientes -->
            <td class="px-5 py-4 text-center">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full
                           bg-blue-50 text-blue-700 text-xs font-bold">
                <%= route._count.clients %>
              </span>
            </td>

            <!-- Badge de estado -->
            <td class="px-5 py-4 text-center">
              <% if (route.isActive) { %>
                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full
                             text-xs font-semibold bg-green-100 text-green-700">
                  ● Activa
                </span>
              <% } else { %>
                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full
                             text-xs font-semibold bg-gray-100 text-gray-500">
                  ● Inactiva
                </span>
              <% } %>
            </td>

            <!-- Acciones -->
            <td class="px-5 py-4">
              <div class="flex items-center justify-end gap-2">
                <a href="/admin/routes/<%= route.id %>"
                  class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg
                         border border-brand-green text-brand-green text-xs font-semibold
                         hover:bg-brand-green hover:text-white transition-colors whitespace-nowrap">
                  📍 Ver Clientes / Mapa
                </a>
                <a href="/admin/routes/<%= route.id %>/edit"
                  class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg
                         border border-gray-300 text-gray-600 text-xs font-semibold
                         hover:bg-gray-100 transition-colors">
                  ✏️ Editar
                </a>
              </div>
            </td>

          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% } %>

</div>

<%- include('../../layouts/footer') %>
