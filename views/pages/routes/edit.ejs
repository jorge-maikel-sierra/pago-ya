<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="page-header">
    <a href="/admin/routes" class="btn-back">←</a>
    <div>
      <h1 class="page-title">Editar Ruta</h1>
      <p class="page-subtitle">Modifica los datos de la ruta.</p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (flashError) { %>
    <div class="flash-error" role="alert">
      <div class="flash-error-content">
        <span class="text-red-600 text-lg">❌</span>
        <p class="flash-error-text"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/routes/<%= route.id %>?_method=PUT"
        class="form-card grid grid-cols-1 gap-5 max-w-2xl">

    <!-- Nombre -->
    <div class="form-group">
      <label for="name" class="form-label">
        Nombre de la ruta <span class="text-red-500">*</span>
      </label>
      <input id="name" name="name" type="text" required
             value="<%= route.name %>"
             placeholder="Ej: Ruta Centro Norte"
             class="form-input" />
    </div>

    <!-- Descripción -->
    <div class="form-group">
      <label for="description" class="form-label">Descripción</label>
      <textarea id="description" name="description" rows="3"
                class="form-textarea"><%= route.description || '' %></textarea>
    </div>

    <!-- Cobrador -->
    <div class="form-group">
      <label for="collectorId" class="form-label">Asignar cobrador</label>
      <select id="collectorId" name="collectorId" class="form-select">
        <option value="">— Sin asignar —</option>
        <% collectors.forEach(function(c) { %>
          <option value="<%= c.id %>" <%= route.collectorId === c.id ? 'selected' : '' %>>
            <%= c.firstName %> <%= c.lastName %>
          </option>
        <% }); %>
      </select>
    </div>

    <!-- Estado -->
    <div class="flex items-center gap-3">
      <input id="isActive" name="isActive" type="checkbox"
             <%= route.isActive ? 'checked' : '' %>
             class="w-5 h-5 rounded border-gray-300 text-brand-green accent-brand-green focus:ring-brand-green" />
      <label for="isActive" class="text-sm text-gray-700">Ruta activa</label>
    </div>

    <!-- Botones -->
    <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-gray-100">
      <button type="submit" class="flex-1 btn-primary">
        💾 Guardar Cambios
      </button>
      <a href="/admin/routes" class="flex-1 btn-secondary justify-center">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>
