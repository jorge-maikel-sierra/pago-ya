<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">
  <div class="flex items-center gap-2">
    <a href="/admin/routes" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-brand-navy transition-colors">← Volver a rutas</a>
  </div>

  <div>
    <h1 class="text-2xl font-bold text-brand-navy">Editar Ruta</h1>
    <p class="text-sm text-gray-500 mt-1">Modifica los datos de la ruta.</p>
  </div>

  <% if (flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-800">
      <p class="font-medium"><%= flashError %></p>
    </div>
  <% } %>

  <form method="POST" action="/admin/routes/<%= route.id %>?_method=PUT" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 grid grid-cols-1 gap-4">
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nombre de la ruta <span class="text-red-500">*</span></label>
      <input id="name" name="name" type="text" required value="<%= route.name %>" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
    </div>

    <div>
      <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
      <textarea id="description" name="description" rows="3" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"><%= route.description || '' %></textarea>
    </div>

    <div>
      <label for="collectorId" class="block text-sm font-medium text-gray-700 mb-1">Asignar cobrador (opcional)</label>
      <select id="collectorId" name="collectorId" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
        <option value="">— Sin asignar —</option>
        <% collectors.forEach(function(c) { %>
          <option value="<%= c.id %>" <%= route.collectorId === c.id ? 'selected' : '' %>><%= c.firstName %> <%= c.lastName %></option>
        <% }); %>
      </select>
    </div>

    <div class="flex items-center gap-3">
      <input id="isActive" name="isActive" type="checkbox" <%= route.isActive ? 'checked' : '' %> class="h-4 w-4" />
      <label for="isActive" class="text-sm text-gray-700">Activa</label>
    </div>

    <div class="flex justify-end gap-3 mt-2">
      <a href="/admin/routes" class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg border border-gray-300 text-gray-600 text-sm">Cancelar</a>
      <button type="submit" class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-brand-green text-white text-sm">Guardar cambios</button>
    </div>
  </form>

</div>

<%- include('../../layouts/footer') %>
