<%
/**
 * Vista: organizations/edit.ejs
 * Formulario para editar una organización existente (Super Admin).
 *
 * Variables locales esperadas:
 * - user: Usuario autenticado
 * - organization: Datos actuales de la organización
 * - flashError: Mensaje de error opcional
 */

/**
 * Tipos de plan disponibles.
 */
const PLAN_OPTIONS = [
  { value: 'BASIC', label: 'Básico', description: 'Funcionalidades esenciales' },
  { value: 'PRO', label: 'Pro', description: 'Reportes avanzados y más usuarios' },
  { value: 'ENTERPRISE', label: 'Enterprise', description: 'Todo incluido + soporte prioritario' },
];

/**
 * Formatea una fecha Date o string a YYYY-MM-DD para el input type="date".
 * Retorna cadena vacía si el valor es nulo.
 *
 * @param {Date|string|null} date
 * @returns {string}
 */
const toDateInputValue = (date) => {
  if (!date) return '';
  const d = new Date(date);
  return d.toISOString().split('T')[0];
};
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="page-header">
    <a href="/admin/organizations"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-200
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Editar Organización</h1>
      <p class="text-sm text-gray-500 mt-1"><%= organization.name %></p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-500 text-lg">❌</span>
        <p class="text-sm font-medium text-red-800"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
       method-override convierte el POST a PUT en el servidor
  ========================================= -->
  <form method="POST" action="/admin/organizations/<%= organization.id %>?_method=PUT"
        class="form-card">

    <!-- ── Información Básica ──────────────────────────────────────── -->
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="form-section-title">📋 Información Básica</h2>
    </div>
    <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-5">

      <!-- Nombre — ocupa toda la fila por su longitud -->
      <div class="sm:col-span-2 lg:col-span-3">
        <label for="name" class="form-label">
          Nombre de la Organización <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          minlength="3"
          maxlength="150"
          placeholder="Ej: Créditos El Sol S.A.S."
          class="form-input"
          value="<%= organization.name %>"
        />
      </div>

      <!-- NIT -->
      <div>
        <label for="nit" class="form-label">NIT</label>
        <input type="text" id="nit" name="nit" maxlength="20"
               placeholder="Ej: 900123456-1" class="form-input"
               value="<%= organization.nit || '' %>" />
      </div>

      <!-- Teléfono -->
      <div>
        <label for="phone" class="form-label">Teléfono</label>
        <input type="tel" id="phone" name="phone" maxlength="20"
               placeholder="Ej: +57 300 123 4567" class="form-input"
               value="<%= organization.phone || '' %>" />
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="form-label">Email</label>
        <input type="email" id="email" name="email" maxlength="100"
               placeholder="Ej: admin@empresa.com" class="form-input"
               value="<%= organization.email || '' %>" />
      </div>

      <!-- Dirección — ocupa 2 columnas para dar más espacio -->
      <div class="sm:col-span-2">
        <label for="address" class="form-label">Dirección</label>
        <input type="text" id="address" name="address" maxlength="255"
               placeholder="Ej: Cra 10 #45-67, Bogotá" class="form-input"
               value="<%= organization.address || '' %>" />
      </div>

      <!-- URL del Logo — ocupa 1 columna restante -->
      <div>
        <label for="logoUrl" class="form-label">URL del Logo</label>
        <input type="url" id="logoUrl" name="logoUrl" maxlength="500"
               placeholder="https://ejemplo.com/logo.png" class="form-input"
               value="<%= organization.logoUrl || '' %>" />
        <p class="form-hint">URL pública de la imagen (opcional).</p>
      </div>

    </div>

    <!-- ── Plan, Mora y Estado ─────────────────────────────────────── -->
    <div class="px-6 py-4 border-t border-b border-gray-100">
      <h2 class="form-section-title">💳 Plan, Mora y Estado</h2>
    </div>
    <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-6 gap-y-5">

      <!-- Tipo de Plan -->
      <div>
        <label for="planType" class="form-label">Tipo de Plan</label>
        <select id="planType" name="planType" class="form-select">
          <% PLAN_OPTIONS.forEach(function(plan) { %>
            <option value="<%= plan.value %>"
              <%= organization.planType === plan.value ? 'selected' : '' %>>
              <%= plan.label %> — <%= plan.description %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Vencimiento Suscripción -->
      <div>
        <label for="subscriptionEnds" class="form-label">Vencimiento Suscripción</label>
        <input type="date" id="subscriptionEnds" name="subscriptionEnds" class="form-input"
               value="<%= toDateInputValue(organization.subscriptionEnds) %>" />
        <p class="form-hint">Vacío = sin límite.</p>
      </div>

      <!-- Días de Gracia -->
      <div>
        <label for="moraGraceDays" class="form-label">Días de Gracia</label>
        <input type="number" id="moraGraceDays" name="moraGraceDays"
               value="<%= organization.moraGraceDays %>"
               min="0" max="30" class="form-input tabular-nums" />
        <p class="form-hint">Días antes de aplicar mora (0-30).</p>
      </div>

      <!-- Multiplicador de Mora -->
      <div>
        <label for="moraMultiplier" class="form-label">Multiplicador Mora</label>
        <input type="number" id="moraMultiplier" name="moraMultiplier"
               value="<%= organization.moraMultiplier %>"
               min="1" max="5" step="0.1" class="form-input tabular-nums" />
        <p class="form-hint">Factor sobre la cuota vencida (1-5x).</p>
      </div>

      <!-- Estado activo -->
      <div class="flex flex-col justify-center">
        <label class="form-label">Estado</label>
        <div class="flex items-center gap-2 mt-1">
          <input
            type="checkbox"
            id="isActive"
            name="isActive"
            <%= organization.isActive ? 'checked' : '' %>
            class="w-5 h-5 rounded border-gray-300 text-brand-green accent-brand-green
                   focus:ring-brand-green"
          />
          <label for="isActive" class="text-sm text-gray-600">Activa</label>
        </div>
      </div>

    </div>

    <!-- =========================================
         BOTONES DE ACCIÓN
    ========================================= -->
    <div class="flex flex-col sm:flex-row gap-3 px-6 py-4 border-t border-gray-100">
      <button type="submit" class="flex-1 btn-primary justify-center">
        💾 Guardar Cambios
      </button>
      <a href="/admin/organizations" class="flex-1 btn-secondary justify-center">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>
