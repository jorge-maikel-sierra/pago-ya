<%
/**
 * Vista: organizations/index.ejs
 * Lista de organizaciones (tenants) para Super Administrador.
 *
 * Variables locales esperadas:
 * - organizations: Array de organizaciones con _count
 * - search: String de búsqueda actual
 * - user: Usuario autenticado
 * - flashSucess, flashError: Mensajes flash opcionales
 */

/**
 * Formatea una fecha a formato colombiano dd/mm/aaaa.
 * @param {Date|string} date
 * @returns {string}
 */
function formatDate(date) {
  if (!date) return '—';
  return new Date(date).toLocaleDateString('es-CO', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

/**
 * Verifica si una fecha ya expiró.
 * @param {Date|string} date
 * @returns {boolean}
 */
function isExpired(date) {
  if (!date) return false;
  return new Date(date) < new Date();
}

/**
 * Obtiene las iniciales de un nombre para el avatar.
 * @param {string} name
 * @returns {string}
 */
function getInitials(name) {
  if (!name) return '??';
  const parts = name.trim().split(' ');
  if (parts.length >= 2) {
    return (parts[0][0] + parts[1][0]).toUpperCase();
  }
  return name.substring(0, 2).toUpperCase();
}

/**
 * Retorna clases y label para el badge del plan.
 * @param {string} planType
 * @returns {{ bg: string, text: string, label: string }}
 */
function planBadge(planType) {
  const map = {
    BASIC:      { bg: 'bg-gray-600', text: 'text-gray-100', label: 'Básico' },
    PRO:        { bg: 'bg-green-600', text: 'text-white', label: 'Pro' },
    ENTERPRISE: { bg: 'bg-yellow-500', text: 'text-brand-navy', label: 'Enterprise' },
  };
  return map[planType] || { bg: 'bg-gray-500', text: 'text-white', label: planType };
}
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO Y BARRA DE ACCIÓN
       Los mensajes flash los renderiza header.ejs → partials/_flash
  ========================================= -->
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">
        Gestión de Organizaciones
        <span class="text-brand-green">(Super Admin)</span>
      </h1>
      <p class="text-sm text-gray-500 mt-1">
        Administra los tenants y sus configuraciones de suscripción
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <!-- Búsqueda -->
      <form method="GET" action="/admin/organizations" class="flex gap-2">
        <input
          type="text"
          name="search"
          value="<%= search %>"
          placeholder="Buscar por nombre o NIT..."
          class="w-full sm:w-64 form-input"
        />
        <button type="submit"
                class="px-4 py-2.5 rounded-lg bg-white border border-gray-200
                       text-gray-600 text-sm font-semibold hover:bg-gray-50 transition">
          🔍
        </button>
        <% if (search) { %>
          <a href="/admin/organizations"
             class="px-4 py-2.5 rounded-lg border border-gray-200 text-gray-500 text-sm
                    hover:bg-gray-50 transition flex items-center">
            ✕
          </a>
        <% } %>
      </form>

      <!-- Botón Nuevo -->
      <a href="/admin/organizations/new"
         class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg
                bg-brand-green text-white text-sm font-semibold shadow-sm
                hover:bg-green-500 transition-colors">
        ➕ Registrar Organización
      </a>
    </div>
  </div>

  <!-- =========================================
       ESTADÍSTICAS RÁPIDAS
  ========================================= -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <%
      const totalOrgs = organizations.length;
      const activeOrgs = organizations.filter(o => o.isActive).length;
      const expiredOrgs = organizations.filter(o => isExpired(o.subscriptionEnds)).length;
      const proOrgs = organizations.filter(o => o.planType === 'PRO' || o.planType === 'ENTERPRISE').length;
    %>
    <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Total</p>
      <p class="text-2xl font-bold text-brand-navy"><%= totalOrgs %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Activas</p>
      <p class="text-2xl font-bold text-brand-green"><%= activeOrgs %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Expiradas</p>
      <p class="text-2xl font-bold text-red-500"><%= expiredOrgs %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Pro/Enterprise</p>
      <p class="text-2xl font-bold text-amber-500"><%= proOrgs %></p>
    </div>
  </div>

  <!-- =========================================
       TABLA DE ORGANIZACIONES
  ========================================= -->
  <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">

    <% if (organizations.length === 0) { %>
      <!-- Estado vacío -->
      <div class="py-16 text-center">
        <span class="text-5xl block mb-4">🏢</span>
        <p class="text-base font-medium text-gray-500">
          <% if (search) { %>
            No se encontraron organizaciones para "<%= search %>"
          <% } else { %>
            No hay organizaciones registradas
          <% } %>
        </p>
        <a href="/admin/organizations/new"
           class="mt-4 inline-flex items-center gap-1 px-4 py-2 rounded-lg bg-brand-green text-white
                  text-sm font-semibold hover:bg-green-500 transition-colors">
          ➕ Registrar Primera Organización
        </a>
      </div>

    <% } else { %>

      <!-- Tabla responsiva -->
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-100 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
                Logo / Nombre
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
                NIT
              </th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
                Plan
              </th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
                Vencimiento
              </th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
                Config. Mora
              </th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
                Usuarios
              </th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
                Acciones
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% organizations.forEach(function(org) { %>
              <%
                const badge = planBadge(org.planType);
                const expired = isExpired(org.subscriptionEnds);
              %>
              <tr class="hover:bg-gray-50 transition-colors">

                <!-- Logo / Nombre -->
                <td class="px-4 py-4">
                  <div class="flex items-center gap-3">
                    <% if (org.logoUrl) { %>
                      <img
                        src="<%= org.logoUrl %>"
                        alt="<%= org.name %>"
                        class="w-10 h-10 rounded-full object-cover border-2 border-gray-200"
                      />
                    <% } else { %>
                      <div class="w-10 h-10 rounded-full bg-brand-green/10 border-2 border-brand-green/30
                                  flex items-center justify-center">
                        <span class="text-sm font-bold text-brand-green">
                          <%= getInitials(org.name) %>
                        </span>
                      </div>
                    <% } %>
                    <div>
                      <p class="font-semibold text-brand-navy"><%= org.name %></p>
                      <% if (!org.isActive) { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-red-50 text-red-600">
                          Inactiva
                        </span>
                      <% } %>
                    </div>
                  </div>
                </td>

                <!-- NIT -->
                <td class="px-4 py-4 text-gray-600">
                  <%= org.nit || 'N/A' %>
                </td>

                <!-- Plan -->
                <td class="px-4 py-4 text-center">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold
                               <%= badge.bg %> <%= badge.text %>">
                    <%= badge.label %>
                  </span>
                </td>

                <!-- Vencimiento Suscripción -->
                <td class="px-4 py-4 text-center">
                  <% if (org.subscriptionEnds) { %>
                    <% if (expired) { %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold
                                   bg-red-50 text-red-600">
                        ⚠️ Expirada
                      </span>
                      <p class="text-xs text-gray-400 mt-1"><%= formatDate(org.subscriptionEnds) %></p>
                    <% } else { %>
                      <span class="text-gray-600"><%= formatDate(org.subscriptionEnds) %></span>
                    <% } %>
                  <% } else { %>
                    <span class="text-gray-400">Sin límite</span>
                  <% } %>
                </td>

                <!-- Configuración Mora -->
                <td class="px-4 py-4 text-center">
                  <div class="text-xs text-gray-500">
                    <span class="text-brand-green font-semibold"><%= org.moraGraceDays %></span> días gracia
                  </div>
                  <div class="text-xs text-gray-500">
                    <span class="text-amber-500 font-semibold"><%= org.moraMultiplier %>x</span> multiplicador
                  </div>
                </td>

                <!-- Usuarios -->
                <td class="px-4 py-4 text-center">
                  <span class="inline-flex items-center gap-1 text-gray-600">
                    👤 <%= org._count.users %>
                  </span>
                </td>

                <!-- Acciones -->
                <td class="px-4 py-4">
                  <div class="flex items-center justify-center gap-2">
                    <a href="/admin/organizations/<%= org.id %>"
                       title="Ver Detalles"
                       class="inline-flex items-center justify-center w-8 h-8 rounded-lg
                              bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors">
                      👁
                    </a>
                    <a href="/admin/organizations/<%= org.id %>/edit"
                       title="Editar"
                       class="inline-flex items-center justify-center w-8 h-8 rounded-lg
                              bg-amber-50 text-amber-600 hover:bg-amber-100 transition-colors">
                      ✏️
                    </a>
                  </div>
                </td>

              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

    <% } %>

  </div>

</div>

<%- include('../../layouts/footer') %>