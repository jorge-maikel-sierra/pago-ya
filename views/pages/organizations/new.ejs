<%
/**
 * Vista: organizations/new.ejs
 * Formulario para registrar una nueva organización (Super Admin).
 *
 * Variables locales esperadas:
 * - user: Usuario autenticado
 * - flashError: Mensaje de error opcional
 */

/**
 * Tipos de plan disponibles.
 */
const PLAN_OPTIONS = [
  { value: 'BASIC', label: 'Básico', description: 'Funcionalidades esenciales' },
  { value: 'PRO', label: 'Pro', description: 'Reportes avanzados y más usuarios' },
  { value: 'ENTERPRISE', label: 'Enterprise', description: 'Todo incluido + soporte prioritario' },
];
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6 bg-brand-navy min-h-screen">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/organizations"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-brand-border
              text-gray-400 hover:bg-brand-surface transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-display font-bold text-white">Registrar Nueva Organización</h1>
      <p class="text-sm text-gray-400 mt-1 font-body">Crea un nuevo tenant en el sistema</p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-900/50 border border-red-600 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-400 text-lg">❌</span>
        <p class="text-sm font-medium text-red-300 font-body"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/organizations"
        class="bg-brand-surface border border-brand-border rounded-xl shadow-lg p-6 max-w-3xl">

    <!-- Sección: Información Básica -->
    <div class="mb-8">
      <h2 class="text-lg font-display font-semibold text-white mb-4 pb-2 border-b border-brand-border">
        📋 Información Básica
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Nombre -->
        <div class="md:col-span-2">
          <label for="name" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Nombre de la Organización <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            minlength="3"
            maxlength="150"
            placeholder="Ej: Créditos El Sol S.A.S."
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm placeholder-gray-500 font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- NIT -->
        <div>
          <label for="nit" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            NIT
          </label>
          <input
            type="text"
            id="nit"
            name="nit"
            maxlength="20"
            placeholder="Ej: 900123456-1"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm placeholder-gray-500 font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Teléfono -->
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Teléfono
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            maxlength="20"
            placeholder="Ej: +57 300 123 4567"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm placeholder-gray-500 font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            maxlength="100"
            placeholder="Ej: admin@empresa.com"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm placeholder-gray-500 font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Dirección -->
        <div>
          <label for="address" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Dirección
          </label>
          <input
            type="text"
            id="address"
            name="address"
            maxlength="255"
            placeholder="Ej: Cra 10 #45-67, Bogotá"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm placeholder-gray-500 font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- URL del Logo -->
        <div class="md:col-span-2">
          <label for="logoUrl" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            URL del Logo
          </label>
          <input
            type="url"
            id="logoUrl"
            name="logoUrl"
            maxlength="500"
            placeholder="https://ejemplo.com/logo.png"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm placeholder-gray-500 font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
          <p class="mt-1 text-xs text-gray-500 font-body">Opcional. URL pública de la imagen del logo.</p>
        </div>

      </div>
    </div>

    <!-- Sección: Plan y Suscripción -->
    <div class="mb-8">
      <h2 class="text-lg font-display font-semibold text-white mb-4 pb-2 border-b border-brand-border">
        💳 Plan y Suscripción
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Tipo de Plan -->
        <div>
          <label for="planType" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Tipo de Plan
          </label>
          <select
            id="planType"
            name="planType"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          >
            <% PLAN_OPTIONS.forEach(function(plan) { %>
              <option value="<%= plan.value %>" <%= plan.value === 'BASIC' ? 'selected' : '' %>>
                <%= plan.label %> - <%= plan.description %>
              </option>
            <% }); %>
          </select>
        </div>

        <!-- Fecha de Vencimiento -->
        <div>
          <label for="subscriptionEnds" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Vencimiento de Suscripción
          </label>
          <input
            type="date"
            id="subscriptionEnds"
            name="subscriptionEnds"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm font-body
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
          <p class="mt-1 text-xs text-gray-500 font-body">Dejar vacío para suscripción sin límite.</p>
        </div>

      </div>
    </div>

    <!-- Sección: Configuración de Mora -->
    <div class="mb-8">
      <h2 class="text-lg font-display font-semibold text-white mb-4 pb-2 border-b border-brand-border">
        ⚠️ Configuración de Mora
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Días de Gracia -->
        <div>
          <label for="moraGraceDays" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Días de Gracia
          </label>
          <input
            type="number"
            id="moraGraceDays"
            name="moraGraceDays"
            value="3"
            min="0"
            max="30"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm font-body tabular-nums
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
          <p class="mt-1 text-xs text-gray-500 font-body">Días antes de aplicar mora (0-30).</p>
        </div>

        <!-- Multiplicador de Mora -->
        <div>
          <label for="moraMultiplier" class="block text-sm font-medium text-gray-300 mb-2 font-body">
            Multiplicador de Mora
          </label>
          <input
            type="number"
            id="moraMultiplier"
            name="moraMultiplier"
            value="1.5"
            min="1"
            max="5"
            step="0.1"
            class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border
                   text-white text-sm font-body tabular-nums
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
          <p class="mt-1 text-xs text-gray-500 font-body">Factor que multiplica la cuota vencida (1-5x).</p>
        </div>

      </div>
    </div>

    <!-- Sección: Estado -->
    <div class="mb-8">
      <h2 class="text-lg font-display font-semibold text-white mb-4 pb-2 border-b border-brand-border">
        🔄 Estado
      </h2>
      <div class="flex items-center gap-3">
        <input
          type="checkbox"
          id="isActive"
          name="isActive"
          checked
          class="w-5 h-5 rounded border-brand-border bg-brand-navy text-brand-green
                 focus:ring-brand-green focus:ring-offset-brand-navy"
        />
        <label for="isActive" class="text-sm text-gray-300 font-body">
          Organización activa (puede operar en el sistema)
        </label>
      </div>
    </div>

    <!-- =========================================
         BOTONES DE ACCIÓN
    ========================================= -->
    <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-brand-border">
      <button type="submit"
              class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg
                     bg-brand-green text-white text-sm font-semibold font-body
                     hover:bg-green-500 transition-colors shadow-md">
        ✅ Registrar Organización
      </button>
      <a href="/admin/organizations"
         class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg
                border border-brand-border text-gray-400 text-sm font-medium font-body
                hover:bg-brand-navy transition-colors">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>
