<%
/**
 * Formatea un valor Decimal/string/number a pesos colombianos COP.
 * @param {number|string|null} amount
 * @returns {string}
 */
function formatCOP(amount) {
  if (amount == null) return '$0';
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: 'COP',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
}

/**
 * Formatea una fecha ISO a dd/mm/aaaa en zona UTC.
 * @param {Date|string|null} date
 * @returns {string}
 */
function formatDate(date) {
  if (!date) return '—';
  return new Date(date).toLocaleDateString('es-CO', {
    day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'UTC',
  });
}

const STATUS_BADGE = {
  ACTIVE:    { bg: 'bg-green-100',  text: 'text-green-700',  label: 'Activo'    },
  PENDING:   { bg: 'bg-yellow-100', text: 'text-yellow-700', label: 'Pendiente' },
  DEFAULTED: { bg: 'bg-red-100',    text: 'text-red-700',    label: 'En mora'   },
};
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div>
    <h1 class="text-2xl font-bold text-brand-navy">Reportes</h1>
    <p class="text-sm text-gray-500 mt-1">Generación y descarga de reportes · Previsualización de cartera</p>
  </div>

  <!-- =========================================
       FORMULARIO DE FILTROS
  ========================================= -->
  <form method="GET" action="/admin/reports"
        class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-4">🔍 Filtros de previsualización</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

      <!-- Fecha desde -->
      <div>
        <label for="dateFrom" class="block text-xs font-medium text-gray-600 mb-1">
          Fecha inicio
        </label>
        <input
          type="date"
          id="dateFrom"
          name="dateFrom"
          value="<%= filters.dateFrom %>"
          class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm
                 text-gray-700 focus:ring-2 focus:ring-brand-green focus:outline-none transition"
        />
      </div>

      <!-- Fecha hasta -->
      <div>
        <label for="dateTo" class="block text-xs font-medium text-gray-600 mb-1">
          Fecha fin
        </label>
        <input
          type="date"
          id="dateTo"
          name="dateTo"
          value="<%= filters.dateTo %>"
          class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm
                 text-gray-700 focus:ring-2 focus:ring-brand-green focus:outline-none transition"
        />
      </div>

      <!-- Filtro por ruta -->
      <div>
        <label for="routeId" class="block text-xs font-medium text-gray-600 mb-1">
          Ruta (opcional)
        </label>
        <select
          id="routeId"
          name="routeId"
          class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm
                 text-gray-700 bg-white focus:ring-2 focus:ring-brand-green focus:outline-none transition"
        >
          <option value="">— Todas las rutas —</option>
          <% routes.forEach(route => { %>
            <option value="<%= route.id %>"
              <%= filters.routeId === route.id ? 'selected' : '' %>>
              <%= route.name %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Botón filtrar -->
      <div class="flex items-end">
        <button type="submit"
          class="w-full px-4 py-2 rounded-lg bg-brand-navy text-white text-sm font-semibold
                 hover:bg-blue-900 transition-colors">
          🔍 Filtrar previsualización
        </button>
      </div>

    </div>

    <!-- Limpiar filtros -->
    <% if (filters.dateFrom || filters.dateTo || filters.routeId) { %>
      <div class="mt-3 flex justify-end">
        <a href="/admin/reports"
          class="text-xs text-gray-400 hover:text-gray-600 transition-colors">
          ✕ Limpiar filtros
        </a>
      </div>
    <% } %>
  </form>

  <!-- =========================================
       TARJETAS DE EXPORTACIÓN
  ========================================= -->
  <div>
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-4">📤 Descargar reporte</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

      <!-- Tarjeta Excel -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 flex flex-col gap-4">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center text-2xl shrink-0">
            📊
          </div>
          <div>
            <h2 class="text-base font-bold text-brand-navy">Cartera del día (Excel)</h2>
            <p class="text-sm text-gray-500 mt-1">
              Descarga la cartera de cobro del día en formato <span class="font-medium">.xlsx</span>.
              Se genera instantáneamente con todos los vencimientos y saldos pendientes.
            </p>
          </div>
        </div>
        <a href="/admin/reports/export?format=xlsx<%= filters.dateFrom ? '&dateFrom=' + filters.dateFrom : '' %>"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg
                 bg-brand-green text-white text-sm font-semibold shadow-sm
                 hover:bg-green-500 transition-colors">
          📥 Descargar Excel
        </a>
      </div>

      <!-- Tarjeta PDF -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 flex flex-col gap-4">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center text-2xl shrink-0">
            📄
          </div>
          <div>
            <h2 class="text-base font-bold text-brand-navy">Reporte PDF</h2>
            <p class="text-sm text-gray-500 mt-1">
              Genera un PDF detallado en <span class="font-medium">segundo plano</span> vía BullMQ.
              Recibirás una notificación cuando esté listo.
            </p>
          </div>
        </div>
        <a href="/admin/reports/export?format=pdf"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg
                 border-2 border-brand-navy text-brand-navy text-sm font-semibold
                 hover:bg-brand-navy hover:text-white transition-colors">
          📄 Generar PDF
        </a>
      </div>

    </div>
  </div>

  <!-- =========================================
       PREVISUALIZACIÓN DE CARTERA
  ========================================= -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">
        👁️ Previsualización de cartera
      </p>
      <span class="text-xs text-gray-400">
        <%= portfolio.length %> registro<%= portfolio.length !== 1 ? 's' : '' %>
        <% if (portfolio.length === 200) { %>
          <span class="text-yellow-600 font-medium">(límite: 200 filas)</span>
        <% } %>
      </span>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-x-auto">

      <% if (portfolio.length === 0) { %>
        <div class="py-16 text-center">
          <span class="text-4xl block mb-3">📋</span>
          <p class="text-sm font-medium text-gray-500">No hay vencimientos para los filtros aplicados</p>
          <p class="text-xs text-gray-400 mt-1">Prueba cambiando el rango de fechas o la ruta seleccionada.</p>
        </div>

      <% } else { %>
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Cliente</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Teléfono</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Cobrador</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Vencimiento</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wide">Cuota esperada</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wide">Pagado</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wide">Saldo pendiente</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% portfolio.forEach(item => { %>
              <%
                const statusInfo = STATUS_BADGE[item.loan.status]
                  || { bg: 'bg-gray-100', text: 'text-gray-500', label: item.loan.status };
                const isPaid = parseFloat(item.amountPaid) >= parseFloat(item.amountDue);
              %>
              <tr class="hover:bg-gray-50 transition-colors
                         <%= isPaid ? 'opacity-60' : '' %>">

                <!-- Cliente -->
                <td class="px-4 py-3">
                  <a href="/admin/loans/<%= item.loan.id %>"
                    class="font-medium text-brand-navy hover:text-brand-green hover:underline transition-colors">
                    <%= item.loan.client.firstName %> <%= item.loan.client.lastName %>
                  </a>
                </td>

                <!-- Teléfono -->
                <td class="px-4 py-3 text-gray-500 text-xs">
                  <%= item.loan.client.phone || '—' %>
                </td>

                <!-- Cobrador -->
                <td class="px-4 py-3 text-gray-600 text-xs">
                  <%= item.loan.collector.firstName %> <%= item.loan.collector.lastName %>
                </td>

                <!-- Vencimiento -->
                <td class="px-4 py-3 text-gray-600">
                  <%= formatDate(item.dueDate) %>
                </td>

                <!-- Cuota esperada -->
                <td class="px-4 py-3 text-right font-medium text-gray-700">
                  <%= formatCOP(item.amountDue) %>
                </td>

                <!-- Pagado -->
                <td class="px-4 py-3 text-right">
                  <% if (isPaid) { %>
                    <span class="text-brand-green font-semibold"><%= formatCOP(item.amountPaid) %></span>
                  <% } else { %>
                    <span class="text-gray-500"><%= formatCOP(item.amountPaid) %></span>
                  <% } %>
                </td>

                <!-- Saldo pendiente -->
                <td class="px-4 py-3 text-right">
                  <% if (parseFloat(item.loan.moraAmount) > 0) { %>
                    <span class="text-red-600 font-semibold">
                      <%= formatCOP(item.loan.outstandingBalance) %>
                      <span class="block text-xs font-normal text-red-400">
                        + mora <%= formatCOP(item.loan.moraAmount) %>
                      </span>
                    </span>
                  <% } else { %>
                    <span class="text-gray-700"><%= formatCOP(item.loan.outstandingBalance) %></span>
                  <% } %>
                </td>

                <!-- Estado -->
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                               <%= statusInfo.bg %> <%= statusInfo.text %>">
                    <%= statusInfo.label %>
                  </span>
                </td>

              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>

    </div>
  </div>

</div>

<%- include('../../layouts/footer') %>
