<%
/**
 * Vista: users/new.ejs
 * Formulario para crear un nuevo usuario.
 *
 * Variables locales esperadas:
 * - user: Usuario autenticado
 * - flashError: Mensaje de error opcional
 */

const ROLE_OPTIONS = [
  { value: 'COLLECTOR', label: 'Cobrador', description: 'Registra pagos en rutas asignadas' },
  { value: 'ADMIN', label: 'Administrador', description: 'Gestiona préstamos, clientes y reportes' },
];
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/users"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-300
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Crear Nuevo Usuario</h1>
      <p class="text-sm text-gray-500 mt-1">Añade un usuario a tu organización</p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-600 text-lg">❌</span>
        <p class="text-sm font-medium text-red-800"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/users"
        class="form-card max-w-2xl">

    <!-- Información Personal -->
    <div class="form-section">
      <h2 class="form-section-title">👤 Información Personal</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Nombre -->
        <div class="form-group">
          <label for="firstName" class="form-label">
            Nombre <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            required
            minlength="2"
            maxlength="80"
            placeholder="Ej: Juan"
            class="form-input"
          />
        </div>

        <!-- Apellido -->
        <div class="form-group">
          <label for="lastName" class="form-label">
            Apellido <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            minlength="2"
            maxlength="80"
            placeholder="Ej: Pérez"
            class="form-input"
          />
        </div>

        <!-- Email -->
        <div class="form-group">
          <label for="email" class="form-label">
            Email <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            maxlength="100"
            placeholder="usuario@empresa.com"
            class="form-input"
          />
        </div>

        <!-- Teléfono -->
        <div class="form-group">
          <label for="phone" class="form-label">Teléfono</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            maxlength="20"
            placeholder="+57 300 123 4567"
            class="form-input"
          />
        </div>

      </div>
    </div>

    <!-- Rol y Acceso -->
    <div class="form-section">
      <h2 class="form-section-title">🔐 Rol y Acceso</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Rol -->
        <div class="form-group">
          <label for="role" class="form-label">
            Rol <span class="text-red-500">*</span>
          </label>
          <select
            id="role"
            name="role"
            required
            class="form-select"
          >
            <% ROLE_OPTIONS.forEach(function(r) { %>
              <option value="<%= r.value %>">
                <%= r.label %> - <%= r.description %>
              </option>
            <% }); %>
          </select>
        </div>

        <!-- Contraseña -->
        <div class="form-group">
          <label for="password" class="form-label">
            Contraseña <span class="text-red-500">*</span>
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="6"
            maxlength="100"
            placeholder="Mínimo 6 caracteres"
            class="form-input"
          />
        </div>

      </div>

      <!-- Estado Activo -->
      <div class="mt-5 flex items-center gap-3">
        <input
          type="checkbox"
          id="isActive"
          name="isActive"
          checked
          class="w-5 h-5 rounded border-gray-300 text-brand-green accent-brand-green focus:ring-brand-green"
        />
        <label for="isActive" class="text-sm text-gray-700">
          Usuario activo (puede iniciar sesión)
        </label>
      </div>
    </div>

    <!-- =========================================
         BOTONES DE ACCIÓN
    ========================================= -->
    <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-gray-100">
      <button type="submit" class="flex-1 btn-primary justify-center">
        ✅ Crear Usuario
      </button>
      <a href="/admin/users" class="flex-1 btn-secondary justify-center">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>