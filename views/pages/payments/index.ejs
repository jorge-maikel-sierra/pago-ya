<%
/**
 * Formatea un valor Decimal/string/number a pesos colombianos COP.
 * @param {number|string|null} amount
 * @returns {string}
 */
function formatCOP(amount) {
  if (amount == null) return '$0';
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: 'COP',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
}

/**
 * Formatea una fecha ISO a dd/mm/aaaa HH:mm en zona local.
 * @param {Date|string|null} date
 * @returns {string}
 */
function formatDateTime(date) {
  if (!date) return '—';
  return new Date(date).toLocaleString('es-CO', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

const METHOD_BADGE = {
  CASH:     { bg: 'bg-green-100',  text: 'text-green-700',  label: 'Efectivo'     },
  TRANSFER: { bg: 'bg-blue-100',   text: 'text-blue-700',   label: 'Transferencia'},
  NEQUI:    { bg: 'bg-purple-100', text: 'text-purple-700', label: 'Nequi'        },
  DAVIPLATA:{ bg: 'bg-yellow-100', text: 'text-yellow-700', label: 'Daviplata'    },
};

/**
 * Construye la query string de paginación conservando los filtros activos.
 * @param {number} p - Número de página destino.
 * @returns {string}
 */
function pageLink(p) {
  const params = new URLSearchParams();
  params.set('page', p);
  if (filters.dateFrom)    params.set('dateFrom',    filters.dateFrom);
  if (filters.dateTo)      params.set('dateTo',      filters.dateTo);
  if (filters.collectorId) params.set('collectorId', filters.collectorId);
  if (filters.paymentMethod) params.set('paymentMethod', filters.paymentMethod);
  return '/admin/payments?' + params.toString();
}
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Historial de Pagos</h1>
      <p class="text-sm text-gray-500 mt-1">
        Registro completo de cobros recibidos ·
        <span class="font-medium text-brand-navy"><%= total %></span>
        pago<%= total !== 1 ? 's' : '' %> encontrado<%= total !== 1 ? 's' : '' %>
      </p>
    </div>
    <a href="/admin/payments/new"
       class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-brand-green text-white text-sm font-semibold shadow-sm hover:bg-green-500 transition-colors">
      💰 Nuevo Pago
    </a>
  </div>

  <!-- =========================================
       FORMULARIO DE FILTROS
  ========================================= -->
  <form method="GET" action="/admin/payments"
        class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-4">🔍 Filtros</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">

      <!-- Fecha desde -->
      <div>
        <label for="dateFrom" class="block text-xs font-medium text-gray-600 mb-1">
          Fecha inicio
        </label>
        <input
          type="date"
          id="dateFrom"
          name="dateFrom"
          value="<%= filters.dateFrom %>"
          class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm
                 text-gray-700 focus:ring-2 focus:ring-brand-green focus:outline-none transition"
        />
      </div>

      <!-- Fecha hasta -->
      <div>
        <label for="dateTo" class="block text-xs font-medium text-gray-600 mb-1">
          Fecha fin
        </label>
        <input
          type="date"
          id="dateTo"
          name="dateTo"
          value="<%= filters.dateTo %>"
          class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm
                 text-gray-700 focus:ring-2 focus:ring-brand-green focus:outline-none transition"
        />
      </div>

      <!-- Cobrador -->
      <div>
        <label for="collectorId" class="block text-xs font-medium text-gray-600 mb-1">
          Cobrador
        </label>
        <select
          id="collectorId"
          name="collectorId"
          class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm
                 text-gray-700 bg-white focus:ring-2 focus:ring-brand-green focus:outline-none transition"
        >
          <option value="">— Todos —</option>
          <% collectors.forEach(function(c) { %>
            <option value="<%= c.id %>"
              <%= filters.collectorId === c.id ? 'selected' : '' %>>
              <%= c.firstName %> <%= c.lastName %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Método de pago -->
      <div>
        <label for="paymentMethod" class="block text-xs font-medium text-gray-600 mb-1">
          Método de pago
        </label>
        <select
          id="paymentMethod"
          name="paymentMethod"
          class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm
                 text-gray-700 bg-white focus:ring-2 focus:ring-brand-green focus:outline-none transition"
        >
          <option value="">— Todos —</option>
          <option value="CASH"      <%= filters.paymentMethod === 'CASH'      ? 'selected' : '' %>>Efectivo</option>
          <option value="TRANSFER"  <%= filters.paymentMethod === 'TRANSFER'  ? 'selected' : '' %>>Transferencia</option>
          <option value="NEQUI"     <%= filters.paymentMethod === 'NEQUI'     ? 'selected' : '' %>>Nequi</option>
          <option value="DAVIPLATA" <%= filters.paymentMethod === 'DAVIPLATA' ? 'selected' : '' %>>Daviplata</option>
        </select>
      </div>

      <!-- Botón filtrar -->
      <div class="flex items-end">
        <button type="submit"
          class="w-full px-4 py-2 rounded-lg bg-brand-navy text-white text-sm font-semibold
                 hover:bg-blue-900 transition-colors">
          🔍 Filtrar
        </button>
      </div>

    </div>

    <!-- Limpiar filtros -->
    <% if (filters.dateFrom || filters.dateTo || filters.collectorId || filters.paymentMethod) { %>
      <div class="mt-3 flex justify-end">
        <a href="/admin/payments"
          class="text-xs text-gray-400 hover:text-gray-600 transition-colors">
          ✕ Limpiar filtros
        </a>
      </div>
    <% } %>
  </form>

  <!-- =========================================
       TABLA DE PAGOS
  ========================================= -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-x-auto">

    <% if (payments.length === 0) { %>
      <div class="py-16 text-center">
        <span class="text-4xl block mb-3">💸</span>
        <p class="text-sm font-medium text-gray-500">No hay pagos para los filtros aplicados</p>
        <p class="text-xs text-gray-400 mt-1">Prueba cambiando el rango de fechas u otros filtros.</p>
      </div>

    <% } else { %>
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Fecha / Hora</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Cliente</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Cobrador</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wide">Capital</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wide">Mora</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wide">Total recibido</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Método</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Telegram</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% payments.forEach(function(payment) { %>
            <%
              const methodInfo = METHOD_BADGE[payment.paymentMethod]
                || { bg: 'bg-gray-100', text: 'text-gray-500', label: payment.paymentMethod };
              const hasMora = parseFloat(payment.moraAmount) > 0;
            %>
            <tr class="hover:bg-gray-50 transition-colors">

              <!-- Fecha / Hora -->
              <td class="px-4 py-3 text-gray-600 whitespace-nowrap">
                <%= formatDateTime(payment.collectedAt) %>
              </td>

              <!-- Cliente -->
              <td class="px-4 py-3">
                <a href="/admin/loans/<%= payment.loan.id %>"
                  class="font-medium text-brand-navy hover:text-brand-green hover:underline transition-colors">
                  <%= payment.loan.client.firstName %> <%= payment.loan.client.lastName %>
                </a>
              </td>

              <!-- Cobrador -->
              <td class="px-4 py-3 text-gray-600 text-xs">
                <% if (payment.collector) { %>
                  <%= payment.collector.firstName %> <%= payment.collector.lastName %>
                <% } else { %>
                  <span class="text-gray-400">—</span>
                <% } %>
              </td>

              <!-- Capital -->
              <td class="px-4 py-3 text-right font-medium text-gray-700">
                <%= formatCOP(payment.amount) %>
              </td>

              <!-- Mora -->
              <td class="px-4 py-3 text-right">
                <% if (hasMora) { %>
                  <span class="text-red-600 font-medium"><%= formatCOP(payment.moraAmount) %></span>
                <% } else { %>
                  <span class="text-gray-400">—</span>
                <% } %>
              </td>

              <!-- Total recibido -->
              <td class="px-4 py-3 text-right font-semibold text-brand-navy">
                <%= formatCOP(payment.totalReceived) %>
              </td>

              <!-- Método de pago -->
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                             <%= methodInfo.bg %> <%= methodInfo.text %>">
                  <%= methodInfo.label %>
                </span>
              </td>

              <!-- Telegram -->
              <td class="px-4 py-3">
                <% if (payment.telegramSent) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                               bg-green-100 text-green-700">
                    ✓ Enviado
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                               bg-gray-100 text-gray-500">
                    Pendiente
                  </span>
                <% } %>
              </td>

            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>

  </div>

  <!-- =========================================
       PAGINACIÓN
  ========================================= -->
  <% if (totalPages > 1) { %>
    <div class="flex items-center justify-between px-1">

      <span class="text-xs text-gray-500">
        Página <span class="font-semibold text-brand-navy"><%= page %></span>
        de <span class="font-semibold text-brand-navy"><%= totalPages %></span>
      </span>

      <div class="flex items-center gap-2">
        <% if (page > 1) { %>
          <a href="<%= pageLink(page - 1) %>"
            class="px-4 py-2 rounded-lg border border-gray-200 text-sm font-medium
                   text-gray-600 hover:bg-gray-50 transition-colors">
            ← Anterior
          </a>
        <% } else { %>
          <span class="px-4 py-2 rounded-lg border border-gray-100 text-sm font-medium
                       text-gray-300 cursor-not-allowed">
            ← Anterior
          </span>
        <% } %>

        <% if (page < totalPages) { %>
          <a href="<%= pageLink(page + 1) %>"
            class="px-4 py-2 rounded-lg border border-gray-200 text-sm font-medium
                   text-gray-600 hover:bg-gray-50 transition-colors">
            Siguiente →
          </a>
        <% } else { %>
          <span class="px-4 py-2 rounded-lg border border-gray-100 text-sm font-medium
                       text-gray-300 cursor-not-allowed">
            Siguiente →
          </span>
        <% } %>
      </div>

    </div>
  <% } %>

</div>

<%- include('../../layouts/footer') %>
