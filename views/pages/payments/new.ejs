<%
/**
 * Vista: payments/new.ejs
 * Formulario para registrar un nuevo pago desde el panel administrativo.
 *
 * Variables locales esperadas:
 * - loans: Array de préstamos activos con client incluido
 * - collectors: Array de cobradores activos
 * - user: Usuario autenticado
 * - flashSucess, flashError: Mensajes flash opcionales
 */

/**
 * Formatea valores monetarios en COP.
 * @param {number|string} amount
 * @returns {string}
 */
function formatCOP(amount) {
  if (amount == null) return '$0';
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: 'COP',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
}

/**
 * Devuelve la fecha de hoy en formato YYYY-MM-DD para inputs date.
 * @returns {string}
 */
function todayISO() {
  const now = new Date();
  const year = now.getFullYear();
  const month = String(now.getMonth() + 1).padStart(2, '0');
  const day = String(now.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/payments"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-300
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Registrar Nuevo Pago</h1>
      <p class="text-sm text-gray-500 mt-1">Ingresa los datos del recaudo realizado</p>
    </div>
  </div>

  <!-- =========================================
       MENSAJES FLASH
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
      <strong>Error:</strong> <%= flashError %>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO DE PAGO
  ========================================= -->
  <form method="POST" action="/admin/payments"
        class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-6 max-w-2xl">

    <!-- Préstamo / Cliente -->
    <div>
      <label for="loanId" class="block text-sm font-medium text-gray-700 mb-2">
        Préstamo / Cliente <span class="text-red-500">*</span>
      </label>
      <select
        id="loanId"
        name="loanId"
        required
        class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
               bg-white focus:ring-2 focus:ring-brand-green focus:border-brand-green
               focus:outline-none transition"
      >
        <option value="">— Selecciona un préstamo —</option>
        <% loans.forEach(function(loan) { %>
          <%
            const clientName = loan.client
              ? loan.client.firstName + ' ' + loan.client.lastName
              : 'Sin cliente';
            const loanInfo = `${clientName} - Saldo: ${formatCOP(loan.outstandingBalance)} - Cuota: ${formatCOP(loan.installmentAmount)}`;
          %>
          <option value="<%= loan.id %>" data-installment="<%= loan.installmentAmount %>">
            <%= loanInfo %>
          </option>
        <% }); %>
      </select>
      <p class="mt-1 text-xs text-gray-400">Solo se muestran préstamos con estado ACTIVO</p>
    </div>

    <!-- Monto a pagar -->
    <div>
      <label for="amountPaid" class="block text-sm font-medium text-gray-700 mb-2">
        Monto Recibido <span class="text-red-500">*</span>
      </label>
      <div class="relative">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm">$</span>
        <input
          type="number"
          id="amountPaid"
          name="amountPaid"
          required
          min="1"
          step="0.01"
          placeholder="0.00"
          class="w-full pl-8 pr-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                 focus:ring-2 focus:ring-brand-green focus:border-brand-green
                 focus:outline-none transition tabular-nums"
        />
      </div>
      <p class="mt-1 text-xs text-gray-400">Ingresa el valor exacto recibido del cliente</p>
    </div>

    <!-- Fecha del pago -->
    <div>
      <label for="paymentDate" class="block text-sm font-medium text-gray-700 mb-2">
        Fecha del Pago <span class="text-red-500">*</span>
      </label>
      <input
        type="date"
        id="paymentDate"
        name="paymentDate"
        required
        value="<%= todayISO() %>"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
               focus:ring-2 focus:ring-brand-green focus:border-brand-green
               focus:outline-none transition"
      />
    </div>

    <!-- Cobrador -->
    <div>
      <label for="collectorId" class="block text-sm font-medium text-gray-700 mb-2">
        Cobrador <span class="text-red-500">*</span>
      </label>
      <select
        id="collectorId"
        name="collectorId"
        required
        class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
               bg-white focus:ring-2 focus:ring-brand-green focus:border-brand-green
               focus:outline-none transition"
      >
        <option value="">— Selecciona un cobrador —</option>
        <% collectors.forEach(function(collector) { %>
          <option value="<%= collector.id %>"
            <%= collector.id === user.id ? 'selected' : '' %>>
            <%= collector.firstName %> <%= collector.lastName %>
          </option>
        <% }); %>
      </select>
    </div>

    <!-- Método de pago -->
    <div>
      <label for="paymentMethod" class="block text-sm font-medium text-gray-700 mb-2">
        Método de Pago
      </label>
      <select
        id="paymentMethod"
        name="paymentMethod"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
               bg-white focus:ring-2 focus:ring-brand-green focus:border-brand-green
               focus:outline-none transition"
      >
        <option value="CASH" selected>Efectivo</option>
        <option value="TRANSFER">Transferencia</option>
        <option value="NEQUI">Nequi</option>
        <option value="DAVIPLATA">Daviplata</option>
      </select>
    </div>

    <!-- Notas -->
    <div>
      <label for="notes" class="block text-sm font-medium text-gray-700 mb-2">
        Notas (opcional)
      </label>
      <textarea
        id="notes"
        name="notes"
        rows="3"
        placeholder="Observaciones adicionales sobre el pago..."
        class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
               focus:ring-2 focus:ring-brand-green focus:border-brand-green
               focus:outline-none transition resize-none"
      ></textarea>
    </div>

    <!-- =========================================
         BOTONES DE ACCIÓN
    ========================================= -->
    <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-gray-100">
      <button type="submit"
              class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg
                     bg-brand-green text-white text-sm font-semibold
                     hover:bg-green-500 transition-colors shadow-sm">
        💰 Registrar Recaudo
      </button>
      <a href="/admin/payments"
         class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg
                border border-gray-300 text-gray-600 text-sm font-medium
                hover:bg-gray-50 transition-colors">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>
