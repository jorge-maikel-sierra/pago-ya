<!--
  Vista: clients/edit.ejs
  Formulario para editar un cliente existente.

  Variables locales esperadas:
  - title: Título de la página
  - user: Usuario autenticado
  - currentPath: Ruta activa para el sidebar
  - client: Objeto cliente a editar
  - routes: Lista de rutas disponibles
  - flashError: Mensaje de error opcional
  - DOCUMENT_OPTIONS: Opciones de tipo de documento
-->
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/clients"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-300
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Editar Cliente</h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= client.firstName %> <%= client.lastName %>
        <span class="text-gray-400">(<%= client.documentType %> <%= client.documentNumber %>)</span>
      </p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-600 text-lg">❌</span>
        <p class="text-sm font-medium text-red-800"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/clients/<%= client.id %>?_method=PUT"
        class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 max-w-3xl">

    <!-- Información Personal -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        👤 Información Personal
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Nombre -->
        <div>
          <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
            Nombre <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            required
            minlength="1"
            maxlength="80"
            value="<%= client.firstName %>"
            placeholder="Ej: Juan"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Apellido -->
        <div>
          <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
            Apellido <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            minlength="1"
            maxlength="80"
            value="<%= client.lastName %>"
            placeholder="Ej: Pérez García"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Tipo de Documento -->
        <div>
          <label for="documentType" class="block text-sm font-medium text-gray-700 mb-2">
            Tipo de Documento <span class="text-red-500">*</span>
          </label>
          <select
            id="documentType"
            name="documentType"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700 bg-white
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          >
            <% for (const opt of DOCUMENT_OPTIONS) { %>
              <option value="<%= opt.value %>" <%= client.documentType === opt.value ? 'selected' : '' %>>
                <%= opt.label %>
              </option>
            <% } %>
          </select>
        </div>

        <!-- Número de Documento -->
        <div>
          <label for="documentNumber" class="block text-sm font-medium text-gray-700 mb-2">
            Número de Documento <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            inputmode="numeric"
            pattern="[0-9]*"
            oninput="this.value = this.value.replace(/\D/g, '')"
            title="Solo dígitos"
            id="documentNumber"
            name="documentNumber"
            required
            minlength="5"
            maxlength="20"
            value="<%= client.documentNumber %>"
            placeholder="Ej: 1234567890"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Teléfono -->
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
            Teléfono
          </label>
          <input
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            oninput="this.value = this.value.replace(/\D/g, '')"
            title="Solo dígitos"
            id="phone"
            name="phone"
            maxlength="20"
            value="<%= client.phone || '' %>"
            placeholder="+57 300 123 4567"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Ruta -->
        <div>
          <label for="routeId" class="block text-sm font-medium text-gray-700 mb-2">
            Ruta de Cobro
          </label>
          <select
            id="routeId"
            name="routeId"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700 bg-white
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          >
            <option value="">Sin asignar</option>
            <% for (const route of routes) { %>
              <option value="<%= route.id %>" <%= client.routeId === route.id ? 'selected' : '' %>>
                <%= route.name %>
              </option>
            <% } %>
          </select>
        </div>

      </div>
    </div>

    <!-- Ubicación -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        📍 Ubicación
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Dirección -->
        <div class="md:col-span-2">
          <label for="address" class="block text-sm font-medium text-gray-700 mb-2">
            Dirección <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="address"
            name="address"
            required
            maxlength="255"
            value="<%= client.address || '' %>"
            placeholder="Ej: Calle 15 # 20-45, Barrio Centro"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Barrio -->
        <div>
          <label for="neighborhood" class="block text-sm font-medium text-gray-700 mb-2">
            Barrio
          </label>
          <input
            type="text"
            id="neighborhood"
            name="neighborhood"
            maxlength="100"
            value="<%= client.neighborhood || '' %>"
            placeholder="Ej: Centro"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Ciudad -->
        <div>
          <label for="city" class="block text-sm font-medium text-gray-700 mb-2">
            Ciudad
          </label>
          <input
            type="text"
            id="city"
            name="city"
            maxlength="100"
            value="<%= client.city || 'Riohacha' %>"
            placeholder="Ej: Riohacha"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

      </div>
    </div>

    <!-- Referencia Personal -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        📞 Referencia Personal
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Nombre de Referencia -->
        <div>
          <label for="referenceContact" class="block text-sm font-medium text-gray-700 mb-2">
            Nombre del Contacto
          </label>
          <input
            type="text"
            id="referenceContact"
            name="referenceContact"
            maxlength="160"
            value="<%= client.referenceContact || '' %>"
            placeholder="Ej: María García (hermana)"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Teléfono de Referencia -->
        <div>
          <label for="referencePhone" class="block text-sm font-medium text-gray-700 mb-2">
            Teléfono de Referencia
          </label>
          <input
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            oninput="this.value = this.value.replace(/\D/g, '')"
            title="Solo dígitos"
            id="referencePhone"
            name="referencePhone"
            maxlength="20"
            value="<%= client.referencePhone || '' %>"
            placeholder="+57 300 987 6543"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

      </div>
    </div>

    <!-- Negocio (Opcional) -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        🏪 Negocio <span class="text-xs text-gray-400 font-normal">(Opcional)</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Nombre del Negocio -->
        <div>
          <label for="businessName" class="block text-sm font-medium text-gray-700 mb-2">
            Nombre del Negocio
          </label>
          <input
            type="text"
            id="businessName"
            name="businessName"
            maxlength="200"
            value="<%= client.businessName || '' %>"
            placeholder="Ej: Tienda El Progreso"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Dirección del Negocio -->
        <div>
          <label for="businessAddress" class="block text-sm font-medium text-gray-700 mb-2">
            Dirección del Negocio
          </label>
          <input
            type="text"
            id="businessAddress"
            name="businessAddress"
            maxlength="255"
            value="<%= client.businessAddress || '' %>"
            placeholder="Ej: Mercado Central, Local 25"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

      </div>
    </div>

    <!-- Notas y Estado -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        📝 Notas y Estado
      </h2>

      <div class="space-y-5">
        <textarea
          id="notes"
          name="notes"
          rows="3"
          maxlength="1000"
          placeholder="Observaciones sobre el cliente..."
          class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                 focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                 transition resize-none"
        ><%= client.notes || '' %></textarea>

        <!-- Estado Activo -->
        <div class="flex items-center gap-3">
          <input type="hidden" name="isActive" value="false" />
          <input
            type="checkbox"
            id="isActive"
            name="isActive"
            value="true"
            <%= client.isActive ? 'checked' : '' %>
            class="w-5 h-5 rounded border-gray-300 text-brand-green focus:ring-brand-green"
          />
          <label for="isActive" class="text-sm font-medium text-gray-700">
            Cliente activo
            <span class="text-gray-400 font-normal">(puede recibir préstamos)</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Botones de Acción -->
    <div class="flex flex-col sm:flex-row items-center gap-3 pt-4 border-t border-gray-100">
      <button type="submit"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3
                     rounded-lg bg-brand-green text-white font-semibold text-sm
                     shadow-sm hover:bg-green-500 transition-colors">
        💾 Guardar Cambios
      </button>
      <a href="/admin/clients"
         class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3
                rounded-lg border border-gray-300 text-gray-600 font-medium text-sm
                hover:bg-gray-50 transition-colors">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>
