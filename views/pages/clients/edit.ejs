<!--
  Vista: clients/edit.ejs
  Formulario para editar un cliente existente.

  Variables locales esperadas:
  - title: Título de la página
  - user: Usuario autenticado
  - currentPath: Ruta activa para el sidebar
  - client: Objeto cliente a editar
  - routes: Lista de rutas disponibles
  - flashError: Mensaje de error opcional
  - DOCUMENT_OPTIONS: Opciones de tipo de documento
-->
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/clients"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-300
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Editar Cliente</h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= client.firstName %> <%= client.lastName %>
        <span class="text-gray-400">(<%= client.documentType %> <%= client.documentNumber %>)</span>
      </p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-600 text-lg">❌</span>
        <p class="text-sm font-medium text-red-800"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/clients/<%= client.id %>?_method=PUT"
    class="form-card max-w-5xl">

    <!-- Información Personal -->
    <div class="form-section">
      <h2 class="form-section-title">👤 Información Personal</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

        <!-- Nombre -->
        <div class="form-group">
          <label for="firstName" class="form-label">
            Nombre <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            required
            minlength="1"
            maxlength="80"
            value="<%= client.firstName %>"
            placeholder="Ej: Juan"
            class="form-input"
          />
        </div>

        <!-- Apellido -->
        <div class="form-group">
          <label for="lastName" class="form-label">
            Apellido <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            minlength="1"
            maxlength="80"
            value="<%= client.lastName %>"
            placeholder="Ej: Pérez García"
            class="form-input"
          />
        </div>

        <!-- Tipo de Documento -->
        <div class="form-group">
          <label for="documentType" class="form-label">
            Tipo de Documento <span class="text-red-500">*</span>
          </label>
          <select
            id="documentType"
            name="documentType"
            required
            class="form-select"
          >
            <% for (const opt of DOCUMENT_OPTIONS) { %>
              <option value="<%= opt.value %>" <%= client.documentType === opt.value ? 'selected' : '' %>>
                <%= opt.label %>
              </option>
            <% } %>
          </select>
        </div>

        <!-- Número de Documento -->
        <div class="form-group">
          <label for="documentNumber" class="form-label">
            Número de Documento <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            inputmode="numeric"
            pattern="[0-9]*"
            oninput="this.value = this.value.replace(/\D/g, '')"
            title="Solo dígitos"
            id="documentNumber"
            name="documentNumber"
            required
            minlength="5"
            maxlength="20"
            value="<%= client.documentNumber %>"
            placeholder="Ej: 1234567890"
            class="form-input"
          />
        </div>

        <!-- Teléfono -->
        <div class="form-group">
          <label for="phone" class="form-label">Teléfono</label>
          <input
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            oninput="this.value = this.value.replace(/\D/g, '')"
            title="Solo dígitos"
            id="phone"
            name="phone"
            maxlength="20"
            value="<%= client.phone || '' %>"
            placeholder="+57 300 123 4567"
            class="form-input"
          />
        </div>

        <!-- Ruta -->
        <div class="form-group">
          <label for="routeId" class="form-label">Ruta de Cobro</label>
          <select
            id="routeId"
            name="routeId"
            class="form-select"
          >
            <option value="">Sin asignar</option>
            <% for (const route of routes) { %>
              <option value="<%= route.id %>" <%= client.routeId === route.id ? 'selected' : '' %>>
                <%= route.name %>
              </option>
            <% } %>
          </select>
        </div>

      </div>
    </div>

    <!-- Ubicación -->
    <div class="form-section">
      <h2 class="form-section-title">📍 Ubicación</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Dirección -->
        <div class="form-group">
          <label for="address" class="form-label">
            Dirección <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="address"
            name="address"
            required
            maxlength="255"
            value="<%= client.address || '' %>"
            placeholder="Ej: Calle 15 # 20-45, Barrio Centro"
            class="form-input"
          />
        </div>

        <!-- Barrio -->
        <div class="form-group">
          <label for="neighborhood" class="form-label">Barrio</label>
          <input
            type="text"
            id="neighborhood"
            name="neighborhood"
            maxlength="100"
            value="<%= client.neighborhood || '' %>"
            placeholder="Ej: Centro"
            class="form-input"
          />
        </div>

        <!-- Ciudad -->
        <div class="form-group">
          <label for="city" class="form-label">Ciudad</label>
          <input
            type="text"
            id="city"
            name="city"
            maxlength="100"
            value="<%= client.city || 'Riohacha' %>"
            placeholder="Ej: Riohacha"
            class="form-input"
          />
        </div>

      </div>
    </div>

    <!-- Notas y Estado -->
    <div class="form-section">
      <h2 class="form-section-title">📝 Notas y Estado</h2>
      <div class="space-y-5">

        <div class="form-group">
          <label for="notes" class="form-label">Notas</label>
          <textarea
            id="notes"
            name="notes"
            rows="3"
            maxlength="1000"
            placeholder="Observaciones sobre el cliente..."
            class="form-textarea"
          ><%= client.notes || '' %></textarea>
        </div>

        <!-- Estado Activo -->
        <div class="flex items-center gap-3">
          <input type="hidden" name="isActive" value="false" />
          <input
            type="checkbox"
            id="isActive"
            name="isActive"
            value="true"
            <%= client.isActive ? 'checked' : '' %>
            class="w-5 h-5 rounded border-gray-300 text-brand-green accent-brand-green focus:ring-brand-green"
          />
          <label for="isActive" class="text-sm font-medium text-gray-700">
            Cliente activo
            <span class="text-gray-400 font-normal">(puede recibir préstamos)</span>
          </label>
        </div>

      </div>
    </div>

    <!-- Botones de Acción -->
    <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-gray-100">
      <button type="submit" class="w-full sm:w-auto btn-primary">
        💾 Guardar Cambios
      </button>
      <a href="/admin/clients" class="w-full sm:w-auto btn-secondary justify-center">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>