<%
/**
 * Vista: clients/new.ejs
 * Formulario para crear un nuevo cliente.
 *
 * Variables locales esperadas:
 * - user: Usuario autenticado
 * - routes: Lista de rutas disponibles
 * - flashError: Mensaje de error opcional
 */

const DOCUMENT_OPTIONS = [
  { value: 'CC', label: 'Cédula de Ciudadanía' },
  { value: 'CE', label: 'Cédula de Extranjería' },
  { value: 'TI', label: 'Tarjeta de Identidad' },
  { value: 'NIT', label: 'NIT' },
  { value: 'PP', label: 'Pasaporte' },
  { value: 'PEP', label: 'PEP' },
];
%>
<%- include('../../layouts/header') %>

<div class="p-4 sm:p-6 lg:p-8 space-y-6">

  <!-- =========================================
       ENCABEZADO
  ========================================= -->
  <div class="flex items-center gap-4">
    <a href="/admin/clients"
       class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-gray-300
              text-gray-500 hover:bg-gray-50 transition-colors">
      ←
    </a>
    <div>
      <h1 class="text-2xl font-bold text-brand-navy">Crear Nuevo Cliente</h1>
      <p class="text-sm text-gray-500 mt-1">Registra un cliente en tu organización</p>
    </div>
  </div>

  <!-- =========================================
       MENSAJE DE ERROR
  ========================================= -->
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
      <div class="flex items-center gap-2">
        <span class="text-red-600 text-lg">❌</span>
        <p class="text-sm font-medium text-red-800"><%= flashError %></p>
      </div>
    </div>
  <% } %>

  <!-- =========================================
       FORMULARIO
  ========================================= -->
  <form method="POST" action="/admin/clients"
        class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 max-w-3xl">

    <!-- Información Personal -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        👤 Información Personal
      </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Nombre -->
        <div>
          <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
            Nombre <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            required
            minlength="1"
            maxlength="80"
            placeholder="Ej: Juan"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Apellido -->
        <div>
          <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
            Apellido <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            minlength="1"
            maxlength="80"
            placeholder="Ej: Pérez García"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Tipo de Documento -->
        <div>
          <label for="documentType" class="block text-sm font-medium text-gray-700 mb-2">
            Tipo de Documento <span class="text-red-500">*</span>
          </label>
          <select
            id="documentType"
            name="documentType"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700 bg-white
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          >
            <% DOCUMENT_OPTIONS.forEach(opt => { %>
              <option value="<%= opt.value %>" <%= opt.value === 'CC' ? 'selected' : '' %>>
                <%= opt.label %>
              </option>
            <% }); %>
          </select>
        </div>

        <!-- Número de Documento -->
        <div>
          <label for="documentNumber" class="block text-sm font-medium text-gray-700 mb-2">
            Número de Documento <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            inputmode="numeric"
            pattern="[0-9]*"
            oninput="this.value = this.value.replace(/\D/g, '')"
            title="Solo dígitos"
            id="documentNumber"
            name="documentNumber"
            required
            minlength="5"
            maxlength="20"
            placeholder="Ej: 1234567890"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Teléfono -->
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
            Teléfono
          </label>
          <input
            type="tel"
            inputmode="numeric"
            pattern="[0-9]*"
            oninput="this.value = this.value.replace(/\D/g, '')"
            title="Solo dígitos"
            id="phone"
            name="phone"
            maxlength="20"
            placeholder="+57 300 123 4567"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Ruta -->
        <div>
          <label for="routeId" class="block text-sm font-medium text-gray-700 mb-2">
            Ruta de Cobro
          </label>
          <select
            id="routeId"
            name="routeId"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700 bg-white
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          >
            <option value="">Sin asignar</option>
            <% routes.forEach(route => { %>
              <option value="<%= route.id %>"><%= route.name %></option>
            <% }); %>
          </select>
        </div>

      </div>
    </div>

    <!-- Ubicación -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-brand-navy mb-4 pb-2 border-b border-gray-100">
        📍 Ubicación
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Dirección -->
        <div>
          <label for="address" class="block text-sm font-medium text-gray-700 mb-2">
            Dirección <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="address"
            name="address"
            required
            maxlength="255"
            placeholder="Ej: Calle 15 # 20-45, Barrio Centro"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Barrio -->
        <div>
          <label for="neighborhood" class="block text-sm font-medium text-gray-700 mb-2">
            Barrio
          </label>
          <input
            type="text"
            id="neighborhood"
            name="neighborhood"
            maxlength="100"
            placeholder="Ej: Centro"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

        <!-- Ciudad -->
        <div>
          <label for="city" class="block text-sm font-medium text-gray-700 mb-2">
            Ciudad
          </label>
          <input
            type="text"
            id="city"
            name="city"
            maxlength="100"
            value="Riohacha"
            placeholder="Ej: Riohacha"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm text-gray-700
                   focus:ring-2 focus:ring-brand-green focus:border-brand-green focus:outline-none
                   transition"
          />
        </div>

      </div>
    </div>


  <!-- Botones de Acción -->
  <div class="flex flex-col sm:flex-row items-center gap-3 pt-6 mt-6 border-t border-gray-100">
      <button type="submit"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3
                     rounded-lg bg-brand-green text-white font-semibold text-sm
                     shadow-sm hover:bg-green-500 transition-colors">
        💾 Crear Cliente
      </button>
      <a href="/admin/clients"
         class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3
                rounded-lg border border-gray-300 text-gray-600 font-medium text-sm
                hover:bg-gray-50 transition-colors">
        Cancelar
      </a>
    </div>

  </form>

</div>

<%- include('../../layouts/footer') %>
