<%- include('../../layouts/header') %>

<%
  const formatCOP = (val) => '$' + Number(val).toLocaleString('es-CO');
  const formatDate = (d) => d ? new Date(d).toLocaleDateString('es-CO') : '—';

  const statusLabel = {
    PENDING:   { text: 'Pendiente',  css: 'bg-yellow-100 text-yellow-700' },
    ACTIVE:    { text: 'Activo',     css: 'bg-green-100  text-green-700'  },
    COMPLETED: { text: 'Completado', css: 'bg-blue-100   text-blue-700'   },
    DEFAULTED: { text: 'Moroso',     css: 'bg-red-100    text-red-700'    },
    CANCELLED: { text: 'Cancelado',  css: 'bg-gray-100   text-gray-600'   },
  };

  const incidentLabel = {
    CLIENT_ABSENT:    'Cliente ausente',
    PARTIAL_PAYMENT:  'Pago parcial',
    REFUSED_PAYMENT:  'Pago rechazado',
    ADDRESS_NOT_FOUND:'Dirección no encontrada',
    OTHER:            'Otro',
  };

  const incidentIcons = {
    CLIENT_ABSENT:     '🚪',
    PARTIAL_PAYMENT:   '💸',
    REFUSED_PAYMENT:   '🚫',
    ADDRESS_NOT_FOUND: '📍',
    OTHER:             '📌',
  };
%>

<div class="p-4 sm:p-6 lg:p-8 space-y-8">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500">
    <a href="/admin/clients" class="hover:text-brand-green transition-colors">Clientes</a>
    <span>›</span>
    <span class="text-gray-700 font-medium"><%= client.firstName %> <%= client.lastName %></span>
  </nav>

  <!-- Perfil del cliente -->
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm p-6">
    <div class="flex flex-col sm:flex-row gap-6">

      <!-- Avatar -->
      <div class="flex-shrink-0">
        <div class="w-24 h-24 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-4xl border-2
          <%= client.isActive ? 'border-green-300' : 'border-red-300' %>">
          👤
        </div>
        <div class="mt-2 text-center">
          <% if (client.isActive) { %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">● Activo</span>
          <% } else { %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700">● Restringido</span>
          <% } %>
        </div>
      </div>

      <!-- Datos principales -->
      <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Nombre completo</p>
          <p class="text-base font-bold text-brand-navy dark:text-white mt-0.5">
            <%= client.firstName %> <%= client.lastName %>
          </p>
        </div>
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Documento</p>
          <p class="text-base text-gray-700 dark:text-gray-200 mt-0.5">
            <%= client.documentType %> <%= client.documentNumber %>
          </p>
        </div>
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Teléfono</p>
          <p class="text-base text-gray-700 dark:text-gray-200 mt-0.5"><%= client.phone || '—' %></p>
        </div>
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Dirección</p>
          <p class="text-base text-gray-700 dark:text-gray-200 mt-0.5"><%= client.address || '—' %></p>
        </div>
        <% if (client.businessName) { %>
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Negocio</p>
            <p class="text-base text-gray-700 dark:text-gray-200 mt-0.5"><%= client.businessName %></p>
          </div>
        <% } %>
        <% if (client.businessAddress) { %>
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Dirección negocio</p>
            <p class="text-base text-gray-700 dark:text-gray-200 mt-0.5"><%= client.businessAddress %></p>
          </div>
        <% } %>
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Registrado</p>
          <p class="text-base text-gray-700 dark:text-gray-200 mt-0.5"><%= formatDate(client.createdAt) %></p>
        </div>
        <% if (client.notes) { %>
          <div class="sm:col-span-2 lg:col-span-3">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Notas</p>
            <p class="text-sm text-gray-600 dark:text-gray-300 mt-0.5"><%= client.notes %></p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Acciones -->
    <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700 flex flex-wrap gap-3">
      <% if (client.isActive) { %>
        <form action="/admin/clients/<%= client.id %>/restrict?_method=PUT" method="POST"
          onsubmit="return confirm('¿Seguro que deseas restringir a este cliente?')">
          <button type="submit"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-semibold
                   hover:bg-red-700 transition-colors shadow-sm">
            🚫 Restringir cliente
          </button>
        </form>
      <% } else { %>
        <form action="/admin/clients/<%= client.id %>/restrict?_method=PUT" method="POST"
          onsubmit="return confirm('¿Seguro que deseas reactivar a este cliente?')">
          <button type="submit"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-brand-green text-white text-sm font-semibold
                   hover:bg-green-500 transition-colors shadow-sm">
            ✅ Reactivar cliente
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Historial de préstamos -->
  <div>
    <h2 class="text-lg font-semibold text-brand-navy dark:text-white mb-4">
      💳 Préstamos
      <span class="ml-2 text-sm font-normal text-gray-500">(<%= loans.length %>)</span>
    </h2>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Capital</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Total</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Pagado</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Saldo</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Cuotas</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Estado</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Desembolso</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-200">Cobrador</th>
          </tr>
        </thead>
        <tbody>
          <% if (loans.length === 0) { %>
            <tr>
              <td colspan="8" class="px-4 py-8 text-center text-gray-400">Sin préstamos registrados.</td>
            </tr>
          <% } else { %>
            <% loans.forEach(function(loan) { %>
              <tr class="border-t border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                <td class="px-4 py-3 font-medium text-brand-navy dark:text-white">
                  <%= formatCOP(loan.principalAmount) %>
                </td>
                <td class="px-4 py-3"><%= formatCOP(loan.totalAmount) %></td>
                <td class="px-4 py-3 text-brand-green"><%= formatCOP(loan.totalPaid) %></td>
                <td class="px-4 py-3 text-yellow-600"><%= formatCOP(loan.outstandingBalance) %></td>
                <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                  <%= loan.paidPayments %> / <%= loan.numberOfPayments %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                               <%= (statusLabel[loan.status] || { css: 'bg-gray-100 text-gray-600' }).css %>">
                    <%= (statusLabel[loan.status] || { text: loan.status }).text %>
                  </span>
                </td>
                <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                  <%= formatDate(loan.disbursementDate) %>
                </td>
                <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                  <%= loan.collector.firstName %> <%= loan.collector.lastName %>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Novedades / Incidentes -->
  <div>
    <h2 class="text-lg font-semibold text-brand-navy dark:text-white mb-4">
      📋 Novedades registradas
      <span class="ml-2 text-sm font-normal text-gray-500">(<%= incidents.length %>)</span>
    </h2>
    <% if (incidents.length === 0) { %>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm p-8 text-center text-gray-400">
        Sin novedades registradas.
      </div>
    <% } else { %>
      <div class="space-y-3">
        <% incidents.forEach(function(incident) { %>
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm px-5 py-4 flex items-start gap-4">
            <span class="text-2xl mt-0.5">
              <%= incidentIcons[incident.type] || '📌' %>
            </span>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">
                  <%= incidentLabel[incident.type] || incident.type %>
                </span>
                <span class="text-xs text-gray-400"><%= formatDate(incident.reportedAt) %></span>
              </div>
              <% if (incident.description) { %>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= incident.description %></p>
              <% } %>
              <p class="text-xs text-gray-400 mt-1">
                Cobrador: <%= incident.collector.firstName %> <%= incident.collector.lastName %>
              </p>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<%- include('../../layouts/footer') %>
