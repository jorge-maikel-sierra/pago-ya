<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Paga Diario Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full bg-brand-navy font-sans antialiased">
  <div class="flex min-h-full items-center justify-center px-4 py-12 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8">
      <div class="text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-brand-green">
          <span class="text-2xl font-bold text-white">$</span>
        </div>
        <h1 class="mt-4 text-2xl font-bold tracking-tight text-white">Crear cuenta</h1>
        <p class="mt-2 text-sm text-gray-400">Regístrate para crear una organización y acceder</p>
      </div>

      <% if (typeof flashError !== 'undefined' && flashError) { %>
        <div class="rounded-lg bg-red-900/50 border border-red-500/30 p-4" role="alert">
          <div class="flex items-center gap-2">
            <span class="text-red-400 text-lg">❌</span>
            <p class="text-sm font-medium text-red-200"><%= flashError %></p>
          </div>
        </div>
      <% } %>

      <% if (typeof flashSucess !== 'undefined' && flashSucess) { %>
        <div class="rounded-lg bg-green-900/50 border border-green-500/30 p-4" role="alert">
          <div class="flex items-center gap-2">
            <span class="text-green-400 text-lg">✅</span>
            <p class="text-sm font-medium text-green-200"><%= flashSucess %></p>
          </div>
        </div>
      <% } %>

      <form action="/register" method="POST" class="mt-8 space-y-6 rounded-xl bg-white/5 p-8 backdrop-blur-sm border border-white/10">
        <div class="space-y-4">
          <div>
            <label for="firstName" class="block text-sm font-medium text-gray-300">Nombre</label>
            <input id="firstName" name="firstName" type="text" required placeholder="Nombre" class="mt-1 block w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-gray-500" />
          </div>

          <div>
            <label for="lastName" class="block text-sm font-medium text-gray-300">Apellido</label>
            <input id="lastName" name="lastName" type="text" placeholder="Apellido (opcional)" class="mt-1 block w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-gray-500" />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-300">Correo electrónico</label>
            <input id="email" name="email" type="email" required placeholder="correo@ejemplo.com" class="mt-1 block w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-gray-500" />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-300">Contraseña</label>
            <input id="password" name="password" type="password" required placeholder="Contraseña" class="mt-1 block w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-white placeholder-gray-500" />
          </div>
        </div>

        <button type="submit" class="flex w-full justify-center rounded-lg bg-brand-green px-4 py-3 text-sm font-semibold text-white">Crear cuenta</button>
      </form>

      <p class="text-center text-xs text-gray-500">
        ¿Ya tienes cuenta? <a href="/admin/login" class="text-white underline">Inicia sesión</a>
      </p>
    </div>
  </div>
</body>
</html>
