# Dependencias
node_modules/

# Variables de entorno — ningún archivo .env debe versionarse
.env
.env.local
.env.test
.env.production
.env.staging
.env.*.local

# Build de Tailwind (se genera con build:css)
public/css/styles.css

# Prisma
prisma/migrations/**/migration_lock.toml
# Cliente generado por Prisma (se regenera con `prisma generate`)
generated/prisma/

# Build
dist/
build/

# Logs
logs/
!logs/.gitkeep
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.github/
.vscode/

# Coverage
coverage/

# Temporal
tmp/
temp/

# Uploads (PDFs generados)
uploads/
!uploads/.gitkeep
